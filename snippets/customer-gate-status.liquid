{%- comment -%}
  Customer Gate Status Snippet
  ----------------------------
  Checks the customer.metafields.customer.status metafield and renders
  a blocking message for non-approved customers on gated pages.

  Statuses:
    - "Approved"  → content renders normally
    - "Pending"   → "Verifying your profile" message
    - "Declined"  → "Access Denied" message
    - "Expired"   → "Access Denied" message
    - blank/nil   → treated as "Pending" (new customer awaiting review)

  Usage in theme.liquid (on gated templates only):
    {% render 'customer-gate-status' %}
    {{ content_for_layout }}
{%- endcomment -%}

{%- unless customer -%}
  {%- comment -%} Not logged in — show login prompt and hide page content {%- endcomment -%}
  {{ 'customer-gate-status.css' | asset_url | stylesheet_tag }}

  <div class="customer-gate customer-gate--login">
    <div class="customer-gate__inner">
      <div class="customer-gate__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
          <polyline points="10 17 15 12 10 7"/>
          <line x1="15" y1="12" x2="3" y2="12"/>
        </svg>
      </div>
      <h1 class="customer-gate__heading">
        <span class="customer-gate__heading-primary">Account</span>
        <span class="customer-gate__heading-accent">Required</span>
      </h1>
      <p class="customer-gate__message">
        You need to be logged in to browse our products. Please log in or create an account to continue.
      </p>
      <div class="customer-gate__actions">
        <a href="/account/login" class="btn-theme">Log In</a>
        <a href="/account/register" class="btn-outline">Create Account</a>
      </div>
    </div>
  </div>

  <div style="display:none !important;">
  {%- comment -%} Hide page content — closed by customer-gate-status-end snippet {%- endcomment -%}

{%- else -%}

{%- assign customer_status = customer.metafields.customer.status | strip -%}

{%- if customer_status == 'Approved' -%}
  {%- comment -%} Customer is approved — do nothing, content renders normally {%- endcomment -%}

{%- elsif customer_status == 'Declined' or customer_status == 'Expired' -%}
  {%- comment -%} Access Denied — Declined or Expired {%- endcomment -%}
  {{ 'customer-gate-status.css' | asset_url | stylesheet_tag }}

  <div class="customer-gate customer-gate--denied">
    <div class="customer-gate__inner">
      <h1 class="customer-gate__heading">
        <span class="customer-gate__heading-primary">Access</span>
        <span class="customer-gate__heading-accent">
          {%- if customer_status == 'Expired' -%}Expired{%- else -%}Denied{%- endif -%}
        </span>
      </h1>
      <p class="customer-gate__message">
        {%- if customer_status == 'Expired' -%}
          Your prescription has expired. To continue shopping, please renew your prescription by contacting our pharmacy team.
        {%- else -%}
          This area is only available to verified patients. If you think this is a mistake, please reach out to our team for assistance.
        {%- endif -%}
      </p>
      <div class="customer-gate__actions">
        <a href="/pages/contact" class="btn-outline btn-outline-white">Support</a>
        <a href="/" class="btn-outline btn-outline-white">Head Home</a>
      </div>
    </div>
  </div>

  <div style="display:none !important;">
  {%- comment -%} Hide page content — closed by customer-gate-status-end snippet {%- endcomment -%}

{%- else -%}
  {%- comment -%} Pending or blank (new customer awaiting review) {%- endcomment -%}
  {{ 'customer-gate-status.css' | asset_url | stylesheet_tag }}

  <div class="customer-gate customer-gate--pending">
    <div class="customer-gate__inner">
      <div class="customer-gate__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <h1 class="customer-gate__heading">
        <span class="customer-gate__heading-primary">Verification</span>
        <span class="customer-gate__heading-accent">In Progress</span>
      </h1>
      <p class="customer-gate__message">
        Your account is being reviewed by our pharmacy team. Once verified, you'll be able to browse and purchase products. We'll notify you by email when your account is ready.
      </p>
      <div class="customer-gate__actions">
        <a href="/pages/contact" class="btn-theme">Support</a>
        <a href="/" class="btn-outline">Head Home</a>
      </div>
    </div>
  </div>

  <div style="display:none !important;">
  {%- comment -%} Hide page content — closed by customer-gate-status-end snippet {%- endcomment -%}

{%- endif -%}

{%- endunless -%}
