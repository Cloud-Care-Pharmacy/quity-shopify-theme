{%- comment -%}
  Customer Gate Status End Snippet
  --------------------------------
  Closes the hidden wrapper opened by customer-gate-status.liquid
  for non-approved customers. Must be rendered after content_for_layout
  on gated pages.
{%- endcomment -%}

{%- unless customer -%}
  </div>{%- comment -%} Close the display:none wrapper (not logged in) {%- endcomment -%}
{%- else -%}
  {%- assign customer_status = customer.metafields.customer.status | strip -%}
  {%- unless customer_status == 'Approved' -%}
    </div>{%- comment -%} Close the display:none wrapper {%- endcomment -%}
  {%- endunless -%}
{%- endunless -%}
