<!-- shipping-policy.liquid -->
<style>
  .shipping-policy-section {
    padding: {{ section.settings.paddingsection }};
  }
  @media (max-width: 767px) {
    .shipping-policy-section {
      padding: {{ section.settings.paddingmobile }};
    }
  }
  .shipping-policy-section {
    background-color: {{ section.settings.bgsection }};
  }
  .shipping-policy__content {
    max-width: 900px;
    margin: 0 auto;
  }
  .shipping-policy__header {
    text-align: center;
    margin-bottom: 40px;
  }
  .shipping-policy__title {
    font-size: 2.5rem;
    margin-bottom: 10px;
    color: {{ section.settings.title_color }};
  }
  .shipping-policy__updated {
    color: {{ section.settings.text_color }};
    opacity: 0.7;
    font-size: 0.9rem;
  }
  .shipping-policy__section {
    margin-bottom: 35px;
  }
  .shipping-policy__section-title {
    font-size: 1.4rem;
    margin-bottom: 15px;
    color: {{ section.settings.title_color }};
    font-weight: 600;
  }
  .shipping-policy__text {
    color: {{ section.settings.text_color }};
    line-height: 1.8;
  }
  .shipping-policy__text p {
    margin-bottom: 15px;
  }
  .shipping-policy__text ul,
  .shipping-policy__text ol {
    margin-bottom: 15px;
    padding-left: 25px;
  }
  .shipping-policy__text li {
    margin-bottom: 8px;
    line-height: 1.7;
  }
  .shipping-policy__info-box {
    background: {{ section.settings.info_box_bg }};
    padding: 25px 30px;
    border-radius: 8px;
    margin: 20px 0;
    border-left: 4px solid {{ section.settings.accent_color }};
  }
  .shipping-policy__info-box-title {
    font-size: 1.1rem;
    margin-bottom: 10px;
    color: {{ section.settings.title_color }};
    font-weight: 600;
  }
  .shipping-policy__contact {
    background: {{ section.settings.contact_bg }};
    padding: 25px 30px;
    border-radius: 8px;
    margin-top: 30px;
  }
  .shipping-policy__contact-title {
    font-size: 1.2rem;
    margin-bottom: 15px;
    color: {{ section.settings.title_color }};
  }
  .shipping-policy__toc {
    background: #f8f9fa;
    padding: 25px 30px;
    border-radius: 8px;
    margin-bottom: 40px;
  }
  .shipping-policy__toc-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 15px;
  }
  .shipping-policy__toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    columns: 2;
  }
  @media (max-width: 767px) {
    .shipping-policy__toc ul {
      columns: 1;
    }
  }
  .shipping-policy__toc li {
    margin-bottom: 8px;
  }
  .shipping-policy__toc a {
    color: {{ section.settings.link_color }};
    text-decoration: none;
  }
  .shipping-policy__toc a:hover {
    text-decoration: underline;
  }
  .shipping-policy__text a {
    color: {{ section.settings.link_color }};
  }
  .shipping-policy__table {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
  }
  .shipping-policy__table th,
  .shipping-policy__table td {
    padding: 12px 15px;
    text-align: left;
    border-bottom: 1px solid #e0e0e0;
  }
  .shipping-policy__table th {
    background: {{ section.settings.info_box_bg }};
    font-weight: 600;
    color: {{ section.settings.title_color }};
  }
  .shipping-policy__table tr:hover {
    background: #fafafa;
  }
</style>

<section class="shipping-policy-section" data-aos="{{ section.settings.animation }}">
  <div class="{{ section.settings.setwidth }}">
    <div class="shipping-policy__content">
      
      <div class="shipping-policy__header">
        <h1 class="shipping-policy__title">{{ section.settings.page_title }}</h1>
        <p class="shipping-policy__updated">{{ section.settings.last_updated }}</p>
      </div>

      {%- if section.settings.show_toc -%}
      <div class="shipping-policy__toc">
        <h3 class="shipping-policy__toc-title">{{ section.settings.toc_title }}</h3>
        <ul>
          {%- for block in section.blocks -%}
            {%- if block.type == 'section' -%}
              <li><a href="#shipping-section-{{ forloop.index }}">{{ block.settings.section_title }}</a></li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
      {%- endif -%}

      {%- if section.settings.intro_text != blank -%}
      <div class="shipping-policy__section">
        <div class="shipping-policy__text rte">
          {{ section.settings.intro_text }}
        </div>
      </div>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'section' -%}
            <div class="shipping-policy__section" id="shipping-section-{{ forloop.index }}" {{ block.shopify_attributes }}>
              {%- if block.settings.section_title != blank -%}
                <h2 class="shipping-policy__section-title">{{ block.settings.section_title }}</h2>
              {%- endif -%}
              {%- if block.settings.section_content != blank -%}
                <div class="shipping-policy__text rte">
                  {{ block.settings.section_content }}
                </div>
              {%- endif -%}
            </div>
          {%- when 'info_box' -%}
            <div class="shipping-policy__info-box" {{ block.shopify_attributes }}>
              {%- if block.settings.info_title != blank -%}
                <h4 class="shipping-policy__info-box-title">{{ block.settings.info_title }}</h4>
              {%- endif -%}
              {%- if block.settings.info_content != blank -%}
                <div class="shipping-policy__text rte">
                  {{ block.settings.info_content }}
                </div>
              {%- endif -%}
            </div>
          {%- when 'contact_box' -%}
            <div class="shipping-policy__contact" {{ block.shopify_attributes }}>
              {%- if block.settings.contact_title != blank -%}
                <h3 class="shipping-policy__contact-title">{{ block.settings.contact_title }}</h3>
              {%- endif -%}
              {%- if block.settings.contact_content != blank -%}
                <div class="shipping-policy__text rte">
                  {{ block.settings.contact_content }}
                </div>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shipping Policy",
  "class": "shipping-policy-wrapper",
  "settings": [
    {
      "type": "select",
      "id": "animation",
      "options": [
        { "value": "", "label": "None" },
        { "value": "fade", "label": "Fade" },
        { "value": "fade-up", "label": "Fade Up" }
      ],
      "default": "fade-up",
      "label": "Animation"
    },
    {
      "type": "select",
      "id": "setwidth",
      "label": "Container Width",
      "default": "container",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "container-fluid", "label": "Full Width" }
      ]
    },
    {
      "type": "color",
      "id": "bgsection",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link Color",
      "default": "#0066cc"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#4CAF50"
    },
    {
      "type": "color",
      "id": "info_box_bg",
      "label": "Info Box Background",
      "default": "#f0f7f0"
    },
    {
      "type": "color",
      "id": "contact_bg",
      "label": "Contact Box Background",
      "default": "#f5f5f5"
    },
    {
      "type": "text",
      "id": "page_title",
      "label": "Page Title",
      "default": "Shipping & Delivery Policy"
    },
    {
      "type": "text",
      "id": "last_updated",
      "label": "Last Updated Text",
      "default": "Last Updated: February 2026"
    },
    {
      "type": "checkbox",
      "id": "show_toc",
      "label": "Show Table of Contents",
      "default": true
    },
    {
      "type": "text",
      "id": "toc_title",
      "label": "Table of Contents Title",
      "default": "Quick Navigation"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Introduction Text",
      "default": "<p>At Quity, we understand that receiving your healthcare products promptly is essential to your wellbeing. We are committed to ensuring your orders are dispatched efficiently and delivered to you as quickly as possible.</p>"
    },
    {
      "type": "text",
      "id": "paddingsection",
      "label": "Section Padding (Desktop)",
      "default": "60px 0px 80px 0px"
    },
    {
      "type": "text",
      "id": "paddingmobile",
      "label": "Section Padding (Mobile)",
      "default": "40px 0px 60px 0px"
    }
  ],
  "blocks": [
    {
      "type": "section",
      "name": "Policy Section",
      "settings": [
        {
          "type": "text",
          "id": "section_title",
          "label": "Section Title",
          "default": "Section Title"
        },
        {
          "type": "richtext",
          "id": "section_content",
          "label": "Section Content",
          "default": "<p>Add your policy content here.</p>"
        }
      ]
    },
    {
      "type": "info_box",
      "name": "Info Box",
      "settings": [
        {
          "type": "text",
          "id": "info_title",
          "label": "Info Box Title",
          "default": "Important Information"
        },
        {
          "type": "richtext",
          "id": "info_content",
          "label": "Info Box Content",
          "default": "<p>Add important information here.</p>"
        }
      ]
    },
    {
      "type": "contact_box",
      "name": "Contact Box",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "contact_title",
          "label": "Contact Title",
          "default": "Questions About Your Delivery?"
        },
        {
          "type": "richtext",
          "id": "contact_content",
          "label": "Contact Content",
          "default": "<p>If you have any questions or concerns about your delivery, please reach out to our team.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shipping Policy",
      "blocks": [
        {
          "type": "section",
          "settings": {
            "section_title": "Delivery Options & Timeframes",
            "section_content": "<p>We offer several delivery options to suit your needs. Shipping methods and estimated delivery times are displayed at checkout based on your location.</p><ul><li><strong>Standard Delivery:</strong> Typically 3-7 business days depending on your location within Australia</li><li><strong>Express Delivery:</strong> 1-3 business days for metro areas, available for eligible orders</li><li><strong>Same Day Delivery:</strong> Available in select metropolitan areas for orders placed before 11:00 AM AEST</li></ul><p>Please note that delivery timeframes commence from when your order is dispatched from our pharmacy, not from when you placed your order. Prescription items may require additional processing time for pharmacist review.</p>"
          }
        },
        {
          "type": "section",
          "settings": {
            "section_title": "Order Processing",
            "section_content": "<p>Our team works diligently to process and dispatch orders promptly:</p><ul><li><strong>Order Cut-off:</strong> Orders placed before 12:00 PM AEST on business days are typically processed and dispatched the same day</li><li><strong>Prescription Verification:</strong> Orders containing prescription medications require verification by our registered pharmacists, which may add processing time</li><li><strong>Business Days:</strong> We dispatch orders Monday to Friday, excluding public holidays</li><li><strong>Order Confirmation:</strong> You will receive an email confirmation once your order has been placed and another when it has been dispatched</li></ul>"
          }
        },
        {
          "type": "section",
          "settings": {
            "section_title": "Delivery Costs",
            "section_content": "<p>Shipping costs are calculated at checkout based on your delivery location and chosen shipping method:</p><ul><li><strong>Free Standard Shipping:</strong> Available on orders over a specified value (details shown at checkout)</li><li><strong>Standard Shipping:</strong> Flat rate for orders under the free shipping threshold</li><li><strong>Express Shipping:</strong> Premium rate for faster delivery</li><li><strong>Regional & Remote Areas:</strong> Additional charges may apply for deliveries to regional and remote locations</li></ul><p>We partner with trusted Australian courier services to ensure your healthcare products arrive safely and on time.</p>"
          }
        },
        {
          "type": "section",
          "settings": {
            "section_title": "Tracking Your Order",
            "section_content": "<p>Stay informed about your delivery with our tracking service:</p><ul><li><strong>Tracking Number:</strong> Once your order is dispatched, you will receive an email containing your tracking number</li><li><strong>Track Online:</strong> Use the tracking number on the carrier's website to monitor your delivery status</li><li><strong>Delivery Notifications:</strong> Our carriers provide SMS and email notifications regarding your delivery progress</li><li><strong>Authority to Leave:</strong> During checkout, you can specify whether the courier may leave parcels in a safe place if you are not home</li></ul>"
          }
        },
        {
          "type": "section",
          "settings": {
            "section_title": "Delivery Address Requirements",
            "section_content": "<p>To ensure successful delivery of your order:</p><ul><li><strong>Accurate Information:</strong> Please double-check that your delivery address is complete and accurate before confirming your order</li><li><strong>Address Changes:</strong> If you need to change your delivery address after ordering, contact us immediately before your order is dispatched. Once dispatched, address changes must be arranged directly with the courier using your tracking number</li><li><strong>PO Box Deliveries:</strong> Standard postal items can be delivered to PO Boxes; however, express courier services typically require a physical street address</li><li><strong>Business Addresses:</strong> For workplace deliveries, please include any relevant floor or department details</li></ul>"
          }
        },
        {
          "type": "section",
          "settings": {
            "section_title": "Signature on Delivery",
            "section_content": "<p>Certain orders may require a signature upon delivery:</p><ul><li><strong>Prescription Medications:</strong> Depending on the medication type, a signature may be required to confirm safe receipt</li><li><strong>High-Value Orders:</strong> Orders above a certain value may be sent with signature required</li><li><strong>Authority to Leave:</strong> If you have provided authority to leave, the courier may leave your parcel in a secure location without requiring a signature</li><li><strong>Missed Delivery:</strong> If you are not available and a signature is required, a card will be left with instructions for redelivery or collection</li></ul>"
          }
        },
        {
          "type": "section",
          "settings": {
            "section_title": "Delivery Issues",
            "section_content": "<p>We strive to ensure every delivery goes smoothly, but occasionally issues may arise:</p><ul><li><strong>Delayed Deliveries:</strong> While we cannot control courier delays, we work closely with our delivery partners to resolve any issues. Please allow a few extra days during peak periods before contacting us</li><li><strong>Damaged Parcels:</strong> If your parcel arrives damaged, please photograph the damage and contact us immediately. Do not dispose of the packaging</li><li><strong>Lost Parcels:</strong> If your tracking shows delivered but you have not received your order, check with neighbours and any safe places before contacting us</li><li><strong>Failed Deliveries:</strong> If a delivery attempt fails and your parcel is returned to us, we will contact you to arrange redelivery. Please note that redelivery may incur additional shipping charges</li></ul>"
          }
        },
        {
          "type": "section",
          "settings": {
            "section_title": "Temperature-Sensitive Products",
            "section_content": "<p>Some healthcare products require temperature-controlled handling:</p><ul><li><strong>Cold Chain Items:</strong> Products requiring refrigeration are packaged with appropriate cooling materials to maintain temperature during transit</li><li><strong>Delivery Timing:</strong> We schedule dispatch of temperature-sensitive items to minimise transit time</li><li><strong>Receiving Cold Items:</strong> Please collect or arrange collection of these items promptly upon delivery and refrigerate immediately</li><li><strong>Seasonal Considerations:</strong> During warmer months, we may adjust dispatch schedules to ensure product integrity</li></ul>"
          }
        },
        {
          "type": "section",
          "settings": {
            "section_title": "Regional & Remote Deliveries",
            "section_content": "<p>We deliver to all areas across Australia, including regional and remote locations:</p><ul><li><strong>Extended Timeframes:</strong> Deliveries to regional and remote areas may take longer than metropolitan deliveries</li><li><strong>Additional Charges:</strong> Some locations may incur additional delivery fees, which will be displayed at checkout</li><li><strong>Alternative Collection:</strong> In some remote areas, parcels may be held at a local post office or parcel locker for collection</li></ul><p>We are committed to making healthcare accessible to all Australians, regardless of location.</p>"
          }
        },
        {
          "type": "section",
          "settings": {
            "section_title": "International Shipping",
            "section_content": "<p>Currently, Quity only ships within Australia. We are unable to dispatch orders to international addresses due to:</p><ul><li>Regulatory requirements for pharmaceutical products</li><li>Prescription medication restrictions</li><li>Temperature control requirements during extended transit</li></ul><p>If you are an Australian customer temporarily overseas, please contact us to discuss alternative arrangements.</p>"
          }
        },
        {
          "type": "contact_box",
          "settings": {
            "contact_title": "Need Help With Your Delivery?",
            "contact_content": "<p>Our customer care team is here to assist with any shipping or delivery enquiries.</p><p><strong>Email:</strong> support@quity.com.au<br><strong>Phone:</strong> 1300 QUITY (1300 784 89)<br><strong>Hours:</strong> Monday to Friday, 9:00 AM - 5:00 PM AEST</p><p>For urgent delivery matters, please include your order number when contacting us.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
