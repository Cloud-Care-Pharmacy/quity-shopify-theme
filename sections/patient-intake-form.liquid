{{ 'patient-intake-form.css' | asset_url | stylesheet_tag }}

{%- unless customer -%}
  <script>
    try { sessionStorage.setItem('quity_return_url', '/pages/questionnaire'); } catch(e) {}
    window.location.replace('/account/register');
  </script>
  <meta http-equiv="refresh" content="0;url=/account/register">
{%- else -%}

<div class="patient-intake-form qy-intake">
  <div class="qy-intake__wrap">
    <patient-intake-form>
          <!-- Progress Indicator -->
          <div class="progress-indicator">
            <ul class="steps-list" id="stepsList">
              <li class="step-item current" data-step="1">
                <div class="step-circle">1</div>
                <div class="step-name">About You</div>
              </li>
              <li class="step-item" data-step="2">
                <div class="step-circle">2</div>
                <div class="step-name">Smoking Status</div>
              </li>
              <li class="step-item" data-step="3">
                <div class="step-circle">3</div>
                <div class="step-name">Smoking History</div>
              </li>
              <li class="step-item" data-step="4">
                <div class="step-circle">4</div>
                <div class="step-name">Vaping Status</div>
              </li>
              <li class="step-item" data-step="5">
                <div class="step-circle">5</div>
                <div class="step-name">Vaping History</div>
              </li>
              <li class="step-item" data-step="6">
                <div class="step-circle">6</div>
                <div class="step-name">Medical History</div>
              </li>
            </ul>
          </div>

          <!-- Success / Confirmation -->
          <div class="success-message" id="successMessage">
            <div class="success-message__inner">
              <div class="success-message__icon">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12.5l4.5 4.5L19 7"></path>
                </svg>
              </div>
              <div class="success-message__eyebrow">Application received</div>
              <h1 class="success-message__heading">Thanks — we&rsquo;ll take it <em>from here.</em></h1>
              <p class="success-message__text">An Australian-registered doctor will review your application within 24 hours. We&rsquo;ll email you at the address you provided &mdash; there&rsquo;s nothing else to do right now.</p>

              <div class="success-message__ref">
                <span class="success-message__ref-label">Reference</span>
                <span class="success-message__ref-code" id="successRef">&mdash;</span>
              </div>

              <div class="success-timeline">
                <div class="success-timeline__item">
                  <span class="success-timeline__index">01</span>
                  <div>
                    <div class="success-timeline__title">Doctor reviews your application</div>
                    <div class="success-timeline__desc">Within 24 hours. They may message you with a question.</div>
                  </div>
                </div>
                <div class="success-timeline__item">
                  <span class="success-timeline__index">02</span>
                  <div>
                    <div class="success-timeline__title">Your script is issued</div>
                    <div class="success-timeline__desc">If approved, we email your 12-month prescription securely.</div>
                  </div>
                </div>
                <div class="success-timeline__item">
                  <span class="success-timeline__index">03</span>
                  <div>
                    <div class="success-timeline__title">Pharmacy ships your order</div>
                    <div class="success-timeline__desc">Overnight from our Sydney pharmacy, in plain packaging.</div>
                  </div>
                </div>
              </div>

              <div class="success-message__actions">
                <a href="/account" class="btn-theme">My Account</a>
                <a href="/" class="btn-outline">Back to Home</a>
              </div>
            </div>
          </div>

          <!-- Form -->
          <form id="patientIntakeForm" class="qy-intake__card" novalidate>

            <!-- Validation banner -->
            <div class="qy-intake__banner" id="formErrorBanner">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 8v4.5"></path><path d="M12 16.3v.4"></path></svg>
              <span>Please review the highlighted fields before continuing.</span>
            </div>

            <!-- Step 1: About You -->
            <div class="form-step active" data-step="1">
              <div class="qy-intake__eyebrow">Step 01 / 06</div>
              <h2 class="step-title">About <em>you</em></h2>

              <div class="section-separator with-label"><span class="sep-label">Personal details</span></div>

              <div class="form-row">
                <div class="field form-group">
                  <label for="firstName" class="required">First name</label>
                  <input type="text" id="firstName" name="firstName" class="field__input form-control" placeholder="First name" required>
                  <div class="error-message">Please enter your first name</div>
                </div>

                <div class="field form-group">
                  <label for="lastName" class="required">Last name</label>
                  <input type="text" id="lastName" name="lastName" class="field__input form-control" placeholder="Last name" required>
                  <div class="error-message">Please enter your last name</div>
                </div>
              </div>

              <div class="form-row dob-gender-row">
                <div class="field form-group">
                  <label class="required">Date of birth</label>
                  {% assign current_year = 'now' | date: '%Y' | plus: 0 %}
                  {% assign max_year = current_year | minus: 18 %}
                  {% assign min_year = current_year | minus: 100 %}
                  {% assign current_month = 'now' | date: '%m' %}
                  {% assign current_day = 'now' | date: '%d' %}
                  {% assign max_date = max_year | append: '-' | append: current_month | append: '-' | append: current_day %}
                  {% assign min_date = min_year | append: '-' | append: current_month | append: '-' | append: current_day %}
                  <input type="hidden" id="dob" name="dob" class="form-control" required>
                  <details class="datefield" data-datepicker data-min="{{ min_date }}" data-max="{{ max_date }}">
                    <summary class="selectish" aria-haspopup="dialog" aria-label="Date of birth">
                      <span class="dp-val ph">DD / MM / YYYY</span>
                      <svg class="ci" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="16" rx="2"></rect><path d="M3 9.5h18M8 3v4M16 3v4"></path></svg>
                    </summary>
                    <div class="cal pop"></div>
                  </details>
                  <div class="error-message">Please enter a valid date of birth (you must be 18+)</div>
                </div>

                <div class="field form-group gender-field">
                  <label class="required">Gender</label>
                  <input type="hidden" id="gender" name="gender" class="form-control" required>
                  <details class="dropdown" data-dropdown>
                    <summary class="selectish" aria-haspopup="listbox" aria-label="Gender">
                      <span class="dd-val ph">Select gender</span>
                      <svg class="cv" viewBox="0 0 12 8"><path d="M1 1l5 5 5-5"></path></svg>
                    </summary>
                    <div class="menu" role="listbox">
                      <div class="opt" data-value="male">Male <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                      <div class="opt" data-value="female">Female <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                      <div class="opt" data-value="non-binary">Non-binary <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                      <div class="opt" data-value="prefer-not-to-say">Prefer not to say <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                      <div class="opt" data-value="other">Other <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                    </div>
                  </details>
                  <div class="error-message">Please select your gender</div>
                </div>
              </div>

              <div class="form-row medicare-row">
                <div class="field form-group">
                  <label for="medicareNumber">Medicare Card #</label>
                  <input type="text" id="medicareNumber" name="medicareNumber" class="field__input form-control" placeholder="e.g., 2123 45670 1">
                </div>

                <div class="field form-group irn-field" id="medicareIRNGroup">
                  <label for="medicareIRN">IRN</label>
                  <input type="text" id="medicareIRN" name="medicareIRN" class="field__input form-control irn-input" maxlength="1" inputmode="numeric" pattern="[1-9]" placeholder="1">
                  <div class="error-message">IRN must be a single digit (1–9)</div>
                </div>

                <div class="field form-group expiry-field" id="medicareExpiryGroup">
                  <label for="medicareExpiry">Expiry</label>
                  <input type="text" id="medicareExpiry" name="medicareExpiry" class="field__input form-control" placeholder="MM/YYYY" maxlength="7" inputmode="numeric">
                  <div class="error-message">Please enter a valid expiry (MM/YYYY)</div>
                </div>
              </div>

              <div class="section-separator with-label"><span class="sep-label">Address</span></div>

              <div class="field form-group">
                <label for="streetAddress" class="required">Street Address</label>
                <input type="text" id="streetAddress" name="streetAddress" class="field__input form-control" required>
                <div class="error-message">Please enter your street address</div>
              </div>

              <div class="form-row">
                <div class="field form-group">
                  <label for="city" class="required">City/Town</label>
                  <input type="text" id="city" name="city" class="field__input form-control" required>
                  <div class="error-message">Please enter your city/town</div>
                </div>

                <div class="field form-group">
                  <label>State</label>
                  <input type="hidden" id="state" name="state" class="form-control">
                  <details class="dropdown" data-dropdown>
                    <summary class="selectish" aria-haspopup="listbox" aria-label="State">
                      <span class="dd-val ph">Select state</span>
                      <svg class="cv" viewBox="0 0 12 8"><path d="M1 1l5 5 5-5"></path></svg>
                    </summary>
                    <div class="menu" role="listbox">
                      <div class="opt" data-value="NSW">New South Wales <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                      <div class="opt" data-value="VIC">Victoria <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                      <div class="opt" data-value="QLD">Queensland <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                      <div class="opt" data-value="SA">South Australia <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                      <div class="opt" data-value="WA">Western Australia <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                      <div class="opt" data-value="TAS">Tasmania <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                      <div class="opt" data-value="NT">Northern Territory <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                      <div class="opt" data-value="ACT">Australian Capital Territory <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                    </div>
                  </details>
                </div>

              </div>

              <div class="form-row">
                <div class="field form-group">
                  <label for="postcode" class="required">Postcode</label>
                  <input type="text" id="postcode" name="postcode" class="field__input form-control" required>
                  <div class="error-message">Please enter your postcode</div>
                </div>

                <div class="field form-group">
                  <label class="required">Country</label>
                  <input type="hidden" id="country" name="country" class="form-control" value="Australia" required>
                  <details class="dropdown" data-dropdown>
                    <summary class="selectish" aria-haspopup="listbox" aria-label="Country">
                      <span class="dd-val">Australia</span>
                      <svg class="cv" viewBox="0 0 12 8"><path d="M1 1l5 5 5-5"></path></svg>
                    </summary>
                    <div class="menu" role="listbox">
                      <div class="opt" data-value="Australia">Australia <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                      <div class="opt" data-value="New Zealand">New Zealand <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                      <div class="opt" data-value="United Kingdom">United Kingdom <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                      <div class="opt" data-value="United States">United States <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                      <div class="opt" data-value="Canada">Canada <svg class="ck" viewBox="0 0 14 10"><path d="M1 5l4 4 8-8"></path></svg></div>
                    </div>
                  </details>
                  <div class="error-message">Please select your country</div>
                </div>
              </div>

              <div class="section-separator with-label"><span class="sep-label">Contact</span></div>

              <div class="form-row">
                <div class="field form-group">
                  <label for="email" class="required">Email</label>
                  <input type="email" id="email" name="email" class="field__input form-control" placeholder="you@email.com" required>
                  <div class="error-message">Please enter a valid email address</div>
                </div>

                <div class="field form-group">
                  <label for="mobile" class="required">Mobile number</label>
                  <input type="tel" id="mobile" name="mobile" class="field__input form-control" placeholder="04XX XXX XXX" required>
                  <div class="error-message">Please enter your mobile number</div>
                </div>
              </div>

              <div class="section-separator with-label"><span class="sep-label">Proof of age</span></div>

              <div class="field form-group">
                <label class="required">Upload proof of age document</label>
                <p class="helper-text">Please upload a clear photo or scan of your driver's licence, passport, or other valid proof of age document.</p>
                <div class="file-upload-zone" id="fileUploadZone">
                  <input type="file" id="proofOfAge" name="proofOfAge" accept="image/jpeg,image/png,image/heic,image/heif,image/webp,application/pdf" class="file-upload-input">
                  <div class="file-upload-placeholder" id="fileUploadPlaceholder">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                      <polyline points="17 8 12 3 7 8"/>
                      <line x1="12" y1="3" x2="12" y2="15"/>
                    </svg>
                    <span class="file-upload-text">Drag &amp; drop your file here or <strong>browse</strong></span>
                    <span class="file-upload-hint">Accepted: Images (JPG, PNG, HEIC) or PDF — Max 10 MB</span>
                  </div>
                  <div class="file-upload-preview" id="fileUploadPreview" style="display:none;">
                    <div class="file-preview-info">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                      </svg>
                      <span class="file-preview-name" id="filePreviewName"></span>
                      <span class="file-preview-size" id="filePreviewSize"></span>
                    </div>
                    <button type="button" class="file-remove-btn" id="fileRemoveBtn" aria-label="Remove file">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                      </svg>
                    </button>
                  </div>
                </div>
                <div class="error-message">Please upload a proof of age document</div>
              </div>
            </div>

            <!-- Step 2: Smoking Status -->
            <div class="form-step" data-step="2">
              <div class="qy-intake__eyebrow">Step 02 / 06</div>
              <h2 class="step-title">Smoking <em>status</em></h2>
              <p class="qy-intake__lead">Tell us where you are right now. There&rsquo;s no wrong answer &mdash; it helps the doctor choose the right option for you.</p>

              <div class="field form-group" style="margin-top:36px;">
                <label class="required">Current smoking status</label>
                <div class="radio-group">
                  <div class="radio-option" data-value="currently-smoking">
                    <input type="radio" id="smokingStatus1" name="smokingStatus" value="currently-smoking" required>
                    <label for="smokingStatus1">I am currently smoking and I'd like to try a nicotine replacement option</label>
                  </div>
                  <div class="radio-option" data-value="quit-with-vaping">
                    <input type="radio" id="smokingStatus2" name="smokingStatus" value="quit-with-vaping" required>
                    <label for="smokingStatus2">I have quit smoking using nicotine replacement products and am managing a nicotine dependence to avoid otherwise smoking cigarettes</label>
                  </div>
                  <div class="radio-option" data-value="managing-dependence">
                    <input type="radio" id="smokingStatus3" name="smokingStatus" value="managing-dependence" required>
                    <label for="smokingStatus3">I am currently using nicotine replacement products to manage a nicotine dependence</label>
                  </div>
                  <div class="radio-option" data-value="never-smoked-or-vaped">
                    <input type="radio" id="smokingStatus4" name="smokingStatus" value="never-smoked-or-vaped" required>
                    <label for="smokingStatus4">I have never smoked before, but would like to try a nicotine replacement option.</label>
                  </div>
                </div>
                <div class="error-message">Please select an option</div>
              </div>
            </div>

            <!-- Step 3: Smoking History -->
            <div class="form-step" data-step="3">
              <div class="qy-intake__eyebrow">Step 03 / 06</div>
              <h2 class="step-title">Smoking <em>history</em></h2>

              <div class="section-separator with-label"><span class="sep-label">Smoking Habits</span></div>

              <div class="field form-group">
                <label class="required">How many cigarettes on average do/did you smoke in a day?</label>
                <div class="radio-group">
                  <div class="radio-option" data-value="1-5">
                    <input type="radio" id="cigarettesPerDay1" name="cigarettesPerDay" value="1-5" required>
                    <label for="cigarettesPerDay1">1–5</label>
                  </div>
                  <div class="radio-option" data-value="6-10">
                    <input type="radio" id="cigarettesPerDay2" name="cigarettesPerDay" value="6-10" required>
                    <label for="cigarettesPerDay2">6–10</label>
                  </div>
                  <div class="radio-option" data-value="10-20">
                    <input type="radio" id="cigarettesPerDay3" name="cigarettesPerDay" value="10-20" required>
                    <label for="cigarettesPerDay3">10–20</label>
                  </div>
                  <div class="radio-option" data-value="over-20">
                    <input type="radio" id="cigarettesPerDay4" name="cigarettesPerDay" value="over-20" required>
                    <label for="cigarettesPerDay4">Over 20</label>
                  </div>
                </div>
                <div class="error-message">Please select an option</div>
              </div>

              <div class="field form-group">
                <label class="required">For how many years have you smoked and/or vaped?</label>
                <div class="radio-group">
                  <div class="radio-option" data-value="less-than-year">
                    <input type="radio" id="yearsSmoked1" name="yearsSmoked" value="less-than-year" required>
                    <label for="yearsSmoked1">Less than a year</label>
                  </div>
                  <div class="radio-option" data-value="1-5-years">
                    <input type="radio" id="yearsSmoked2" name="yearsSmoked" value="1-5-years" required>
                    <label for="yearsSmoked2">1–5 years</label>
                  </div>
                  <div class="radio-option" data-value="6-10-years">
                    <input type="radio" id="yearsSmoked3" name="yearsSmoked" value="6-10-years" required>
                    <label for="yearsSmoked3">6–10 years</label>
                  </div>
                  <div class="radio-option" data-value="over-10-years">
                    <input type="radio" id="yearsSmoked4" name="yearsSmoked" value="over-10-years" required>
                    <label for="yearsSmoked4">Over 10 years</label>
                  </div>
                </div>
                <div class="error-message">Please select an option</div>
              </div>

              <div class="section-separator with-label"><span class="sep-label">Quit Attempts</span></div>

              <div class="field form-group">
                <label class="required">How many times have you tried quitting?</label>
                <div class="radio-group">
                  <div class="radio-option" data-value="1-5">
                    <input type="radio" id="timesTriedQuitting1" name="timesTriedQuitting" value="1-5" required>
                    <label for="timesTriedQuitting1">1–5</label>
                  </div>
                  <div class="radio-option" data-value="6-10">
                    <input type="radio" id="timesTriedQuitting2" name="timesTriedQuitting" value="6-10" required>
                    <label for="timesTriedQuitting2">6–10</label>
                  </div>
                  <div class="radio-option" data-value="more-than-10">
                    <input type="radio" id="timesTriedQuitting3" name="timesTriedQuitting" value="more-than-10" required>
                    <label for="timesTriedQuitting3">More than 10</label>
                  </div>
                </div>
                <div class="error-message">Please select an option</div>
              </div>

              <div class="field form-group">
                <label class="required">What has motivated you to quit smoking?</label>
                <div class="checkbox-group">
                  <div class="checkbox-option" data-value="health">
                    <input type="checkbox" id="quitMotivation1" name="quitMotivation" value="health">
                    <label for="quitMotivation1">Health</label>
                  </div>
                  <div class="checkbox-option" data-value="wellbeing">
                    <input type="checkbox" id="quitMotivation2" name="quitMotivation" value="wellbeing">
                    <label for="quitMotivation2">General well-being</label>
                  </div>
                  <div class="checkbox-option" data-value="cost">
                    <input type="checkbox" id="quitMotivation3" name="quitMotivation" value="cost">
                    <label for="quitMotivation3">Cost</label>
                  </div>
                  <div class="checkbox-option" data-value="family-friends">
                    <input type="checkbox" id="quitMotivation4" name="quitMotivation" value="family-friends">
                    <label for="quitMotivation4">Family/friends</label>
                  </div>
                </div>
                <div class="error-message">Please select at least one option</div>
              </div>

              <div class="field form-group">
                <label class="required">Which quitting methods have you tried so far? Please check ALL that apply.</label>
                <div class="helper-text">Nicotine vaping prescription may be considered appropriate for people who have tried nicotine replacement therapy (like patches, gums, etc.) and pharmacotherapy quitting methods but were unsuccessful and are still motivated to quit smoking.</div>
                <div class="checkbox-group">
                  <div class="checkbox-option" data-value="first-line-nrt">
                    <input type="checkbox" id="quitMethod1" name="quitMethods" value="first-line-nrt">
                    <label for="quitMethod1">Nicotine replacement therapy (patches, gums, lozenges, etc.)</label>
                  </div>
                  <div class="checkbox-option" data-value="pharmacotherapy">
                    <input type="checkbox" id="quitMethod2" name="quitMethods" value="pharmacotherapy">
                    <label for="quitMethod2">Pharmacotherapy Varenicline (Champix) or Bupropion (Zyban)</label>
                  </div>
                  <div class="checkbox-option" data-value="quit-using-vaping">
                    <input type="checkbox" id="quitMethod3" name="quitMethods" value="quit-using-vaping">
                    <label for="quitMethod3">I have already quit using vaping products and am managing a nicotine dependence</label>
                  </div>
                  <div class="checkbox-option" data-value="not-tried">
                    <input type="checkbox" id="quitMethod4" name="quitMethods" value="not-tried">
                    <label for="quitMethod4">I have not tried to quit before</label>
                  </div>
                </div>
                <div class="error-message">Please select at least one method</div>
              </div>

              <div class="field form-group">
                <label class="required" for="quitMethodExplanation">Please explain why the quitting methods selected didn't work for you, or why you have not tried these treatments. This information is crucial for determining your eligibility for nicotine vaping products.</label>
                <div class="helper-text">The doctor needs this information to determine if this treatment is appropriate. Please provide information about cravings, side effects or relapses back to smoking.</div>
                <textarea id="quitMethodExplanation" name="quitMethodExplanation" class="form-control" placeholder="Please explain why previous quitting methods didn't work or why you haven't tried them..." required></textarea>
                <div class="error-message">Please provide an explanation</div>
              </div>

              <div class="field form-group">
                <label class="required">How long ago was your last cigarette?</label>
                <div class="radio-group">
                  <div class="radio-option" data-value="today">
                    <input type="radio" id="lastCigarette1" name="lastCigarette" value="today" required>
                    <label for="lastCigarette1">Today</label>
                  </div>
                  <div class="radio-option" data-value="past-week">
                    <input type="radio" id="lastCigarette2" name="lastCigarette" value="past-week" required>
                    <label for="lastCigarette2">Within the past week</label>
                  </div>
                  <div class="radio-option" data-value="past-month">
                    <input type="radio" id="lastCigarette3" name="lastCigarette" value="past-month" required>
                    <label for="lastCigarette3">Within the past month</label>
                  </div>
                  <div class="radio-option" data-value="1-6-months">
                    <input type="radio" id="lastCigarette4" name="lastCigarette" value="1-6-months" required>
                    <label for="lastCigarette4">1-6 months ago</label>
                  </div>
                  <div class="radio-option" data-value="6-12-months">
                    <input type="radio" id="lastCigarette5" name="lastCigarette" value="6-12-months" required>
                    <label for="lastCigarette5">6-12 months ago</label>
                  </div>
                  <div class="radio-option" data-value="over-year">
                    <input type="radio" id="lastCigarette6" name="lastCigarette" value="over-year" required>
                    <label for="lastCigarette6">Over one year ago</label>
                  </div>
                </div>
                <div class="error-message">Please select an option</div>
              </div>
            </div>

            <!-- Step 4: Vaping Status -->
            <div class="form-step" data-step="4">
              <div class="qy-intake__eyebrow">Step 04 / 06</div>
              <h2 class="step-title">Vaping <em>status</em></h2>

              <div class="field form-group" style="margin-top:36px;">
                <label class="required">Have you ever vaped?</label>
                <div class="radio-cards">
                  <div class="radio-card" data-value="yes">
                    <input type="radio" id="vapingStatus1" name="vapingStatus" value="yes" required>
                    <label for="vapingStatus1">Yes</label>
                  </div>
                  <div class="radio-card" data-value="no">
                    <input type="radio" id="vapingStatus2" name="vapingStatus" value="no" required>
                    <label for="vapingStatus2">No</label>
                  </div>
                </div>
                <div class="error-message">Please select an option</div>
              </div>
            </div>

            <!-- Step 5: Vaping History -->
            <div class="form-step" data-step="5">
              <div class="qy-intake__eyebrow">Step 05 / 06</div>
              <h2 class="step-title">Vaping <em>history</em></h2>

              <div class="section-separator with-label"><span class="sep-label">Vaping Preferences</span></div>

              <div class="field form-group">
                <label class="required">Which vaping method has worked best for you?</label>
                <div class="radio-group">
                  <div class="radio-option" data-value="pods">
                    <input type="radio" id="vapingMethod1" name="vapingMethod" value="pods" required>
                    <label for="vapingMethod1">Pods</label>
                  </div>
                  <div class="radio-option" data-value="e-liquid">
                    <input type="radio" id="vapingMethod2" name="vapingMethod" value="e-liquid" required>
                    <label for="vapingMethod2">E-liquid</label>
                  </div>
                  <div class="radio-option" data-value="disposable">
                    <input type="radio" id="vapingMethod3" name="vapingMethod" value="disposable" required>
                    <label for="vapingMethod3">Disposable devices</label>
                  </div>
                  <div class="radio-option" data-value="other">
                    <input type="radio" id="vapingMethod4" name="vapingMethod" value="other" required>
                    <label for="vapingMethod4">Other</label>
                  </div>
                </div>
                <div class="error-message">Please select an option</div>
              </div>

              <div class="form-row">
                <div class="field form-group">
                  <label for="vapingStrength" class="required">What is the minimum strength that has been effective to avoid smoking?</label>
                  <input type="text" id="vapingStrength" name="vapingStrength" class="field__input form-control" placeholder="e.g., 20mg/ml" required>
                  <div class="checkbox-standalone idk-option" data-value="idk-strength">
                    <input type="checkbox" id="idkVapingStrength" name="idkVapingStrength">
                    <label for="idkVapingStrength">I don't know</label>
                  </div>
                  <div class="error-message">Please enter the minimum effective strength</div>
                </div>

                <div class="field form-group">
                  <label for="vapingVolume" class="required">How many mL's of liquid do you estimate that you use per day?</label>
                  <input type="text" id="vapingVolume" name="vapingVolume" class="field__input form-control" placeholder="e.g., 5ml" required>
                  <div class="checkbox-standalone idk-option" data-value="idk-volume">
                    <input type="checkbox" id="idkVapingVolume" name="idkVapingVolume">
                    <label for="idkVapingVolume">I don't know</label>
                  </div>
                  <div class="error-message">Please enter the volume you use per day</div>
                </div>
              </div>

              <div class="section-separator"></div>

              <div class="field form-group">
                <label for="vapingNotes">Is there anything else you would like to add about your vaping?</label>
                <textarea id="vapingNotes" name="vapingNotes" class="form-control" placeholder="Any additional information..."></textarea>
              </div>
            </div>

            <!-- Step 6: Medical History -->
            <div class="form-step" data-step="6">
              <div class="qy-intake__eyebrow">Step 06 / 06</div>
              <h2 class="step-title">Medical <em>history</em></h2>

              <div class="section-separator with-label"><span class="sep-label">Medical Conditions</span></div>

              <div class="field form-group">
                <label class="required">Do you have any medical conditions, particularly uncontrolled hypertension, unstable heart disease, abnormal heart rhythm, or chronic lung disease?</label>
                <div class="radio-group">
                  <div class="radio-option" data-value="yes">
                    <input type="radio" id="hasMedicalConditions1" name="hasMedicalConditions" value="yes" required>
                    <label for="hasMedicalConditions1">Yes</label>
                  </div>
                  <div class="radio-option" data-value="no">
                    <input type="radio" id="hasMedicalConditions2" name="hasMedicalConditions" value="no" required>
                    <label for="hasMedicalConditions2">No</label>
                  </div>
                </div>
                <div class="error-message">Please select an option</div>
              </div>

              <div class="field form-group" id="medicalConditionsGroup" style="display: none;">
                <label class="required">Please select all conditions that apply</label>
                <div class="checkbox-group">
                  <div class="checkbox-option" data-value="hypertension">
                    <input type="checkbox" id="condition1" name="medicalConditions" value="hypertension">
                    <label for="condition1">Uncontrolled hypertension</label>
                  </div>
                  <div class="checkbox-option" data-value="heart-attack">
                    <input type="checkbox" id="condition2" name="medicalConditions" value="heart-attack">
                    <label for="condition2">Myocardial infarction (heart attack)</label>
                  </div>
                  <div class="checkbox-option" data-value="stroke">
                    <input type="checkbox" id="condition3" name="medicalConditions" value="stroke">
                    <label for="condition3">Stroke</label>
                  </div>
                  <div class="checkbox-option" data-value="cancer">
                    <input type="checkbox" id="condition4" name="medicalConditions" value="cancer">
                    <label for="condition4">Cancer</label>
                  </div>
                  <div class="checkbox-option" data-value="other">
                    <input type="checkbox" id="condition5" name="medicalConditions" value="other">
                    <label for="condition5">Other</label>
                  </div>
                </div>
                <div class="error-message">Please select at least one condition</div>
              </div>

              <div class="field form-group" id="medicalConditionsOtherGroup" style="display: none;">
                <label for="medicalConditionsOther">Please describe your other medical condition(s)</label>
                <textarea id="medicalConditionsOther" name="medicalConditionsOther" class="form-control" placeholder="Please list any other medical conditions..."></textarea>
                <div class="error-message">Please describe your other condition(s)</div>
              </div>

              <div class="field form-group">
                <label class="required">Do you currently take any medication(s)?</label>
                <div class="radio-group">
                  <div class="radio-option" data-value="yes">
                    <input type="radio" id="takesMedication1" name="takesMedication" value="yes" required>
                    <label for="takesMedication1">Yes</label>
                  </div>
                  <div class="radio-option" data-value="no">
                    <input type="radio" id="takesMedication2" name="takesMedication" value="no" required>
                    <label for="takesMedication2">No</label>
                  </div>
                </div>
                <div class="error-message">Please select an option</div>
              </div>

              <div class="field form-group" id="medicationsListGroup" style="display: none;">
                <label>Are you currently taking any of the following high-risk medications?</label>
                <div class="checkbox-group">
                  <div class="checkbox-option" data-value="olanzapine">
                    <input type="checkbox" id="highRiskMed1" name="highRiskMedications" value="olanzapine">
                    <label for="highRiskMed1">Olanzapine</label>
                  </div>
                  <div class="checkbox-option" data-value="warfarin">
                    <input type="checkbox" id="highRiskMed2" name="highRiskMedications" value="warfarin">
                    <label for="highRiskMed2">Warfarin</label>
                  </div>
                  <div class="checkbox-option" data-value="other">
                    <input type="checkbox" id="highRiskMed3" name="highRiskMedications" value="other">
                    <label for="highRiskMed3">Other</label>
                  </div>
                </div>
              </div>

              <div class="field form-group" id="medicationsTextGroup" style="display: none;">
                <label for="medicationsList">Please list all medications you are currently taking</label>
                <textarea id="medicationsList" name="medicationsList" class="form-control" placeholder="List all medications you are currently taking..."></textarea>
                <div class="error-message">Please list your medications</div>
              </div>

              <div class="section-separator with-label"><span class="sep-label">Cardiovascular Health</span></div>

              <div class="field form-group">
                <label class="required">Have you had a stroke, heart attack, irregular heartbeat, uncontrolled hypertension or angina in the past month?</label>
                <div class="radio-group">
                  <div class="radio-option" data-value="yes">
                    <input type="radio" id="cardiovascular1" name="cardiovascular" value="yes" required>
                    <label for="cardiovascular1">Yes</label>
                  </div>
                  <div class="radio-option" data-value="no">
                    <input type="radio" id="cardiovascular2" name="cardiovascular" value="no" required>
                    <label for="cardiovascular2">No</label>
                  </div>
                </div>
                <div class="error-message">Please select an option</div>
              </div>

              <div class="section-separator with-label"><span class="sep-label">Pregnancy Status</span></div>

              <div class="field form-group">
                <label class="required">Are you breastfeeding, pregnant, or planning to become pregnant within the next 12 months?</label>
                <div class="radio-group">
                  <div class="radio-option" data-value="yes">
                    <input type="radio" id="pregnancy1" name="pregnancy" value="yes" required>
                    <label for="pregnancy1">Yes</label>
                  </div>
                  <div class="radio-option" data-value="no">
                    <input type="radio" id="pregnancy2" name="pregnancy" value="no" required>
                    <label for="pregnancy2">No</label>
                  </div>
                </div>
                <div class="error-message">Please select an option</div>
              </div>

              <div class="section-separator with-label"><span class="sep-label">Additional Information</span></div>

              <div class="field form-group">
                <label for="forwardEmail">Email</label>
                <div class="helper-text">Your documents will be securely emailed to you, and no one else, unless you request otherwise. If you would like us to also forward your prescription to a pharmacy, supplier or friend/carer, please enter their email address.</div>
                <input type="email" id="forwardEmail" name="forwardEmail" class="field__input form-control" placeholder="Optional forwarding email">
              </div>

              <div class="field form-group">
                <label for="additionalNotes">Is there anything else you would like to mention before proceeding?</label>
                <textarea id="additionalNotes" name="additionalNotes" class="form-control" placeholder="Any additional information..."></textarea>
              </div>

              <div class="section-separator with-label"><span class="sep-label">Safety Acknowledgement</span></div>

              <div class="field form-group">
                <div class="safety-info">
                  Complete abstinence from smoking and vaping is the safest option for your health. Nicotine is addictive, and the long-term risks of vaping are unknown. No nicotine vaping products are currently approved by the TGA, and their safety has not been thoroughly assessed. Quity, and its doctors, cannot guarantee the safety of any vaping product. To minimise harm, only short-term use of e-cigarettes is recommended, and dual use (vaping plus smoking) should be avoided.
                </div>
                <div class="checkbox-standalone" data-value="acknowledged">
                  <input type="checkbox" id="safetyAcknowledgment" name="safetyAcknowledgment" required>
                  <label for="safetyAcknowledgment">I confirm that I have read and understand the above safety information</label>
                </div>
                <div class="error-message">You must acknowledge the safety information to proceed</div>
              </div>
            </div>

            <!-- Navigation -->
            <div class="form-navigation">
              <button type="button" class="btn-back" id="btnBack" disabled>Back</button>
              <button type="button" class="btn-next" id="btnNext">Next</button>
              <button type="submit" class="btn-submit" id="btnSubmit" style="display: none;">Submit application</button>
            </div>
          </form>
        </patient-intake-form>

  </div>
</div>

<script src="{{ 'patient-intake-form.js' | asset_url }}" defer></script>

{%- endunless -%}

{% schema %}
{
  "name": "Patient Intake Form",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
