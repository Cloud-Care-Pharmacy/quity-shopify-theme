    "about-faq-section": {
      "type": "faq-accordion",
      "blocks": {
        "faq-1": {
          "type": "faq",
          "settings": {
            "faq_title": "Are your doctors registered in Australia?",
            "faq_des": "<p>Yes. All Quity prescribers are Australian-registered medical practitioners with specific training and authorisation in smoking cessation therapies, including TGA Authorised Prescriber status for nicotine vaping products where applicable.</p>"
          }
        },
        "faq-2": {
          "type": "faq",
          "settings": {
            "faq_title": "Are all products compliant with Australian regulations?",
            "faq_des": "<p>Absolutely. Every product available through our pharmacy is compliant with Australian regulations and meets the Therapeutic Goods Order 110 (TGO 110) safety and quality requirements. You can verify listed products on the TGA website.</p>"
          }
        },
        "faq-3": {
          "type": "faq",
          "settings": {
            "faq_title": "How does the telehealth consultation work?",
            "faq_des": "<p>After you register and complete your online health assessment, our medical team reviews your information within 24 hours. Depending on your needs, we use a combination of secure online messaging and phone or video consultations — giving you flexible access to clinical support without needing to visit a clinic in person.</p>"
          }
        },
        "faq-4": {
          "type": "faq",
          "settings": {
            "faq_title": "What makes Quity different from other services?",
            "faq_des": "<p>Quity is focused on delivering measurable, positive outcomes for every patient. We offer a range of evidence-based treatment options because the same approach does not work for everyone. Our service combines registered healthcare professionals, fast turnaround times, express delivery, and ongoing support — all within a judgement-free environment built around your individual needs.</p>"
          }
        },
        "faq-5": {
          "type": "faq",
          "settings": {
            "faq_title": "Do you have Australian-based customer support?",
            "faq_des": "<p>Yes. Our patient support team is based in Australia and available to help with any questions about your assessment, prescription, orders, or treatment journey. You can reach us via our contact page or by emailing support@quity.com.au.</p>"
          }
        }
      },
      "block_order": [
