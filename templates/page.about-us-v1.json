    "24a28133-2e01-4361-8b00-ad164f72336f": {
      "type": "image-content",
      "blocks": {
        "template--16716887458110__24a28133-2e01-4361-8b00-ad164f72336f-1666686767d1a98887-1": {
          "type": "text_block",
          "settings": {
            "width": "100%",
            "bgtext": "#ffffff",
            "title_color": "rgba(0,0,0,0)",
            "subtitle": "Evidence-Based Approach",
            "title": "How Our Service Works",
            "size_text": "h3",
            "text": "<div class=\"pr-lg-5 mr-lg-4\">\n<p>At Quity, we follow a structured, clinician-led process designed to give you the best chance of success. Our team of Australian-registered doctors and pharmacists stay current with both domestic and international research on smoking cessation — so the advice you receive is grounded in the latest evidence.</p>\n<ul style=\"list-style: none; padding: 0; margin-top: 20px;\">\n<li style=\"margin-bottom: 12px; padding-left: 25px; position: relative;\">\n<strong style=\"color: #333;\">1. Register &amp; Assess</strong> — Create your account and complete a secure online health assessment covering your smoking history and medical background.</li>\n<li style=\"margin-bottom: 12px; padding-left: 25px; position: relative;\">\n<strong style=\"color: #333;\">2. Clinical Review</strong> — An Australian-registered practitioner reviews your assessment and determines the most appropriate treatment pathway.</li>\n<li style=\"margin-bottom: 12px; padding-left: 25px; position: relative;\">\n<strong style=\"color: #333;\">3. Treatment &amp; Support</strong> — Receive your approved therapy with express delivery and ongoing clinical support throughout your quit journey.</li>\n</ul>\n</div>",
            "answer_content": "",
            "style_btn": "btn-underline btn-underline-white",
            "button": "",
            "link": "",
            "enable_padding": false,
            "align": "left"
          }
        },
