    "about-vision-section": {
      "type": "advanced-content",
      "blocks": {
        "vision-text-block": {
          "type": "html",
          "settings": {
            "width": "60%",
            "title": "",
            "color_title": "#000000",
            "sub": "",
            "color_sub": "#000000",
            "code": "<div class=\"text-center px-lg-5\">\n<span class=\"subtop\">OUR VISION</span>\n<h3 class=\"mt-3 mb-4\">Building Healthier Communities, One Patient at a Time</h3>\n<p style=\"font-size: 1.05rem; line-height: 1.8;\">We envision a future where Australians have convenient, affordable access to the clinical tools and professional guidance they need to overcome nicotine addiction. By prioritising transparency, evidence-based care, and genuine patient outcomes, Quity is working to reduce the burden of smoking-related disease across the country.</p>\n<p style=\"font-size: 1.05rem; line-height: 1.8; margin-top: 15px;\">Whether you are taking your first steps toward quitting or you have tried before and need a fresh approach, our team is here to support you — without judgement, with expertise, and with a plan tailored to your needs.</p>\n</div>",
            "color_des": "#000000",
            "button_text": "",
            "link_button": "",
            "align": "center",
            "box_align": "center",
            "text_align": "center"
          }
        }
      },
