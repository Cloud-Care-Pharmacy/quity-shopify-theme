<!-- customers/register.liquid -->
<style>
  .qy-getstarted {
    min-height: 100vh;
    background: #FFFFFF;
    font-family: 'Jost', sans-serif;
    color: #0F1110;
    -webkit-font-smoothing: antialiased;
    display: flex;
    flex-direction: column;
  }
  .qy-getstarted *,
  .qy-getstarted *::before,
  .qy-getstarted *::after { box-sizing: border-box; }

  /* These are stroke/line icons — opt out of the theme's global
     `svg, .icon { fill: currentColor; width:16px; height:16px }` rule
     (assets/theme.css) which otherwise renders them as solid shapes. */
  .qy-getstarted svg { fill: none; }
  .qy-getstarted .qy-promise-icon svg { width: 21px; height: 21px; }
  .qy-getstarted .qy-trust-pill svg { width: 14px; height: 14px; }
  .qy-getstarted .qy-secure svg { width: 14px; height: 14px; }

  /* The theme sets font-family on h1–h6 (var(--g-font-1)) and on
     p/input/button (var(--g-font-2)) via element selectors in
     assets/theme.css, which beat the Jost inherited from the container.
     Re-assert Jost on those elements; the serif (em) accent keeps its own,
     more-specific rule. Also clear the theme's heading text-transform so the
     headline/card heading stay sentence case. */
  .qy-getstarted .qy-h1,
  .qy-getstarted .qy-card-h,
  .qy-getstarted .qy-lead,
  .qy-getstarted .qy-card-sub,
  .qy-getstarted .qy-label,
  .qy-getstarted .qy-secure,
  .qy-getstarted .qy-login-row,
  .qy-getstarted .qy-login { font-family: 'Jost', sans-serif; }
  .qy-getstarted .qy-h1,
  .qy-getstarted .qy-card-h { text-transform: none; }

  .qy-getstarted .qy-grid {
    flex: 1;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 64px;
    align-items: center;
    max-width: 1280px;
    width: 100%;
    margin: 0 auto;
    padding: 48px 48px 80px;
  }
  .qy-getstarted .qy-left,
  .qy-getstarted .qy-card { min-width: 0; }

  /* Left — value proposition */
  .qy-getstarted .qy-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #8A8F8C;
    margin-bottom: 18px;
  }

  .qy-getstarted .qy-h1 {
    margin: 0;
    font-weight: 400;
    font-size: clamp(44px, 5vw, 64px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: #0F1110;
  }
  .qy-getstarted .qy-h1 em {
    font-family: 'Newsreader', serif;
    font-style: italic;
    font-weight: 400;
    color: #E55B4F;
  }

  .qy-getstarted .qy-lead {
    max-width: 460px;
    font-size: 20px;
    font-weight: 400;
    line-height: 1.5;
    color: #5B615E;
    margin: 20px 0 0;
  }

  .qy-getstarted .qy-promise {
    display: flex;
    flex-direction: column;
    margin-top: 36px;
    max-width: 500px;
    border-top: 1px solid #E3E0D7;
  }
  .qy-getstarted .qy-promise-row {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 20px 2px;
    border-bottom: 1px solid #E3E0D7;
  }
  .qy-getstarted .qy-promise-idx {
    flex: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: #8A8F8C;
  }
  /* Ink-stroke icon tile — coral is kept scarce on this surface */
  .qy-getstarted .qy-promise-icon {
    flex: none;
    width: 44px;
    height: 44px;
    border: 1px solid #E3E0D7;
    background: #FAF8F2;
    border-radius: 8px;
    display: grid;
    place-items: center;
    color: #0F1110;
  }
  .qy-getstarted .qy-promise-title {
    font-weight: 500;
    font-size: 17px;
    color: #0F1110;
  }
  .qy-getstarted .qy-promise-sub {
    font-size: 14px;
    color: #5B615E;
    margin-top: 2px;
  }

  /* Trust pills */
  .qy-getstarted .qy-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }
  .qy-getstarted .qy-trust-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FAF8F2;
    border: 1px solid #E3E0D7;
    border-radius: 999px;
    padding: 8px 14px;
    font-size: 12.5px;
    color: #5B615E;
  }

  /* Right — form card (paper surface on the white page; inputs stay white) */
  .qy-getstarted .qy-card {
    background: #F4F2EC;
    border: 1px solid #E3E0D7;
    border-radius: 14px;
    padding: 38px 38px 32px;
    box-shadow: 0 4px 14px -4px rgba(0,0,0,0.08);
  }
  .qy-getstarted .qy-kicker {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #8A8F8C;
    margin-bottom: 12px;
  }
  .qy-getstarted .qy-card-h {
    margin: 0;
    font-weight: 400;
    font-size: 30px;
    letter-spacing: -0.015em;
    line-height: 1.1;
    color: #0F1110;
  }
  .qy-getstarted .qy-card-h em {
    font-family: 'Newsreader', serif;
    font-style: italic;
    font-weight: 400;
    color: #E55B4F;
  }
  .qy-getstarted .qy-card-sub {
    font-size: 14.5px;
    font-weight: 400;
    color: #5B615E;
    margin: 8px 0 0;
    line-height: 1.5;
  }

  .qy-getstarted .qy-names {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 13px;
    margin-top: 24px;
  }
  .qy-getstarted .qy-field { min-width: 0; }
  .qy-getstarted .qy-field--mt { margin-top: 14px; }

  .qy-getstarted .qy-label {
    display: block;
    font-size: 12.5px;
    font-weight: 500;
    color: #1C1F1D;
    margin-bottom: 7px;
  }

  .qy-getstarted .qy-input {
    width: 100%;
    min-width: 0;
    height: 48px;
    margin: 0;
    font-family: 'Jost', sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #0F1110;
    background: #FFFFFF;
    border: 1px solid #E3E0D7;
    border-radius: 8px;
    padding: 0 15px;
    transition: border-color .12s ease, box-shadow .12s ease;
  }
  .qy-getstarted .qy-input::placeholder { color: #8A8F8C; opacity: 1; }
  .qy-getstarted .qy-input:focus {
    outline: none;
    border-color: #E55B4F;
    box-shadow: 0 0 0 3px rgba(229,91,79,0.12);
  }

  /* Submit — ink pill, coral on hover */
  .qy-getstarted .qy-submit {
    width: 100%;
    height: 48px;
    margin-top: 22px;
    padding: 0;
    background: #0F1110;
    color: #F4F2EC;
    border: 1px solid #0F1110;
    border-radius: 999px;
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    font-size: 15px;
    cursor: pointer;
    transition: background .12s ease, border-color .12s ease;
  }
  .qy-getstarted .qy-submit:hover { background: #E55B4F; border-color: #E55B4F; }

  .qy-getstarted .qy-secure {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 14px 0 0;
    font-size: 12.5px;
    font-weight: 400;
    color: #8A8F8C;
  }

  .qy-getstarted .qy-divider { height: 1px; background: #EDEAE1; margin: 22px 0 16px; }

  .qy-getstarted .qy-login-row {
    text-align: center;
    font-size: 14.5px;
    font-weight: 400;
    color: #5B615E;
    margin: 0;
  }
  .qy-getstarted .qy-login {
    color: #0F1110;
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color .12s ease;
  }
  .qy-getstarted .qy-login:hover { border-color: #E55B4F; }

  /* Inline form errors (Shopify default_errors) */
  .qy-getstarted .errors,
  .qy-getstarted .form-message {
    list-style: none;
    margin: 22px 0 0;
    padding: 13px 16px;
    border: 1px solid #E55B4F;
    border-radius: 8px;
    background: #FBE9E6;
    color: #B83F36;
    font-size: 13.5px;
    font-weight: 400;
  }
  .qy-getstarted .errors li { margin: 0; }
  .qy-getstarted .errors li + li { margin-top: 4px; }

  /* Client-side per-field validation (inline errors, password hint, banner) */
  .qy-getstarted .qy-input--error { border-color: #E55B4F; box-shadow: 0 0 0 3px rgba(229,91,79,0.12); }
  .qy-getstarted .error-message {
    display: none;
    margin: 7px 0 0;
    font-size: 12.5px;
    font-weight: 400;
    color: #B83F36;
  }
  .qy-getstarted .error-message.show { display: block; }
  .qy-getstarted .qy-hint { margin: 7px 0 0; font-size: 12px; font-weight: 400; color: #8A8F8C; }
  .qy-getstarted .qy-error-banner {
    display: none;
    margin: 18px 0 0;
    padding: 13px 16px;
    border: 1px solid #E55B4F;
    border-radius: 8px;
    background: #FBE9E6;
    color: #B83F36;
    font-size: 13.5px;
    font-weight: 400;
  }
  .qy-getstarted .qy-error-banner.show { display: block; }

  /* Responsive */
  @media (max-width: 900px) {
    .qy-getstarted .qy-grid {
      grid-template-columns: 1fr;
      gap: 44px;
      padding: 40px 24px 64px;
    }
    /* Surface the sign-up form first on mobile so the fields aren't pushed
       below the fold by the marketing column (which is first in the DOM). */
    .qy-getstarted .qy-card { order: 1; }
    .qy-getstarted .qy-left { order: 2; }
    .qy-getstarted .qy-promise,
    .qy-getstarted .qy-lead { max-width: none; }
  }
  @media (max-width: 480px) {
    .qy-getstarted .qy-card { padding: 30px 22px 26px; }
    .qy-getstarted .qy-names { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .qy-getstarted .qy-input,
    .qy-getstarted .qy-submit,
    .qy-getstarted .qy-login { transition: none; }
  }
</style>

<section class="qy-getstarted">
  <main class="qy-grid">

    <!-- LEFT: value proposition -->
    <section class="qy-left">
      <div class="qy-eyebrow">Get started · 12-month script</div>

      <h1 class="qy-h1">Apply for your<br>12-month <em>prescription</em></h1>

      <p class="qy-lead">Create your account and apply for a prescription. No upfront cost &mdash; you only pay if you&rsquo;re approved.</p>

      <div class="qy-promise">
        <div class="qy-promise-row">
          <span class="qy-promise-idx">01</span>
          <span class="qy-promise-icon">
            <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"></circle><path d="M12 7.5v5l3 1.8"></path></svg>
          </span>
          <div>
            <div class="qy-promise-title">Doctor reviewed within 24 hours</div>
            <div class="qy-promise-sub">An Australian-registered prescriber assesses your application.</div>
          </div>
        </div>
        <div class="qy-promise-row">
          <span class="qy-promise-idx">02</span>
          <span class="qy-promise-icon">
            <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 7h11v8H3z"></path><path d="M14 10h4l3 3v2h-7z"></path><circle cx="7" cy="17" r="1.7"></circle><circle cx="17" cy="17" r="1.7"></circle></svg>
          </span>
          <div>
            <div class="qy-promise-title">Free express shipping on first order</div>
            <div class="qy-promise-sub">If approved, dispatched overnight from our pharmacy.</div>
          </div>
        </div>
      </div>

      <div class="qy-trust">
        <div class="qy-trust-pill">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0F1110" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"></path></svg>
          TGA-licensed pharmacy
        </div>
        <div class="qy-trust-pill">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0F1110" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"></circle><path d="M8.5 12.5l2.2 2.2 4.8-5"></path></svg>
          AHPRA-registered doctors
        </div>
        <div class="qy-trust-pill">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0F1110" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="11" width="14" height="9" rx="1.5"></rect><path d="M8 11V8a4 4 0 0 1 8 0v3"></path></svg>
          Data stored in Australia
        </div>
      </div>
    </section>

    <!-- RIGHT: account creation form -->
    <section class="qy-card">
      <div class="qy-kicker">Start your application</div>
      <h2 class="qy-card-h">Create your <em>account</em></h2>
      <p class="qy-card-sub">Takes about 2 minutes. A valid prescription is needed to browse and purchase.</p>

      {%- form 'create_customer', novalidate: 'novalidate', id: 'QyRegisterForm' -%}
        <input type="hidden" name="return_to" value="/account">
        {{ form.errors | default_errors }}

        <div class="qy-error-banner" id="RegisterErrorBanner">Please check the highlighted fields below.</div>

        <div class="qy-names">
          <div class="qy-field">
            <label for="FirstName" class="qy-label">First name</label>
            <input class="qy-input" type="text" name="customer[first_name]" id="FirstName" placeholder="First name" autocomplete="given-name" {% if form.first_name %}value="{{ form.first_name }}"{% endif %}>
            <div class="error-message" id="FirstNameError">Please enter your first name.</div>
          </div>
          <div class="qy-field">
            <label for="LastName" class="qy-label">Last name</label>
            <input class="qy-input" type="text" name="customer[last_name]" id="LastName" placeholder="Last name" autocomplete="family-name" {% if form.last_name %}value="{{ form.last_name }}"{% endif %}>
            <div class="error-message" id="LastNameError">Please enter your last name.</div>
          </div>
        </div>

        <div class="qy-field qy-field--mt">
          <label for="Email" class="qy-label">Email address</label>
          <input class="qy-input" type="email" name="customer[email]" id="Email" placeholder="you@email.com" autocomplete="email" autocorrect="off" autocapitalize="off" {% if form.email %}value="{{ form.email }}"{% endif %}>
          <div class="error-message" id="EmailError">Please enter a valid email address.</div>
        </div>

        <div class="qy-field qy-field--mt">
          <label for="CreatePassword" class="qy-label">Password</label>
          <input class="qy-input" type="password" name="customer[password]" id="CreatePassword" placeholder="Create a password" autocomplete="new-password">
          <div class="qy-hint" id="PasswordHint">Use at least 5 characters.</div>
          <div class="error-message" id="CreatePasswordError">Please create a password with at least 5 characters.</div>
        </div>

        <button type="submit" class="qy-submit">Create account &amp; apply</button>

        <p class="qy-secure">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="11" width="14" height="9" rx="1.5"></rect><path d="M8 11V8a4 4 0 0 1 8 0v3"></path></svg>
          Free to apply. No charge until a doctor approves.
        </p>
      {%- endform -%}

      <div class="qy-divider"></div>
      <p class="qy-login-row">Already a member? <a href="/account/login" class="qy-login">Log in</a></p>
    </section>

  </main>
</section>

<script>
  (function () {
    var EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    function setError(input, msgEl, message) {
      if (input) input.classList.add('qy-input--error');
      if (msgEl) { if (message) msgEl.textContent = message; msgEl.classList.add('show'); }
    }
    function clearError(input, msgEl) {
      if (input) input.classList.remove('qy-input--error');
      if (msgEl) msgEl.classList.remove('show');
    }
    var FIELDS = [
      { input: '#FirstName', error: '#FirstNameError', validate: function (v) {
          return (v || '').trim() ? null : 'Please enter your first name.';
        } },
      { input: '#LastName', error: '#LastNameError', validate: function (v) {
          return (v || '').trim() ? null : 'Please enter your last name.';
        } },
      { input: '#Email', error: '#EmailError', validate: function (v) {
          v = (v || '').trim();
          if (!v) return 'Please enter your email address.';
          if (!EMAIL_RE.test(v)) return 'Please enter a valid email address.';
          return null;
        } },
      { input: '#CreatePassword', error: '#CreatePasswordError', validate: function (v) {
          if (!v) return 'Please create a password.';
          if (v.length < 5) return 'Password must be at least 5 characters.';
          return null;
        } }
    ];
    // Custom inline validation (the form carries `novalidate`, so the native
    // browser bubble never shows). Mirrors the intake form's per-field error UX.
    document.addEventListener('DOMContentLoaded', function () {
      var form = document.getElementById('QyRegisterForm');
      if (!form) return;
      var banner = document.getElementById('RegisterErrorBanner');
      form.addEventListener('submit', function (e) {
        var firstInvalid = null;
        FIELDS.forEach(function (f) {
          var input = form.querySelector(f.input);
          if (!input) return;
          var msgEl = form.querySelector(f.error);
          var err = f.validate(input.value);
          if (err) { setError(input, msgEl, err); if (!firstInvalid) firstInvalid = input; }
          else { clearError(input, msgEl); }
        });
        if (firstInvalid) {
          e.preventDefault();
          if (banner) banner.classList.add('show');
          firstInvalid.focus();
        } else if (banner) {
          banner.classList.remove('show');
        }
      });
      FIELDS.forEach(function (f) {
        var input = form.querySelector(f.input);
        if (!input) return;
        var msgEl = form.querySelector(f.error);
        input.addEventListener('input', function () {
          if (!f.validate(input.value)) {
            clearError(input, msgEl);
            if (banner && !form.querySelector('.qy-input--error')) banner.classList.remove('show');
          }
        });
      });
    });
  })();
</script>
