{{ 'account-dashboard.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign status = customer.metafields.customer.status | strip
  assign has_active_script = false
  if status == 'Approved'
    assign has_active_script = true
  endif

  comment
    Prescription detail (optional metafields) — shown only when present.
  endcomment
  assign rx_name = customer.metafields.customer.medication | strip
  if rx_name == blank
    assign rx_name = 'Your prescription is active'
  endif
  assign rx_prescriber = customer.metafields.customer.prescriber | strip
  assign rx_script_id = customer.metafields.customer.script_id | strip
  assign rx_repeats = customer.metafields.customer.repeats | strip
  assign rx_next_delivery = customer.metafields.customer.next_delivery | strip

  comment
    Expiry date is stored as a `expiry:DD Mon YYYY` customer tag.
  endcomment
  assign expiry_date = ''
  for tag in customer.tags
    if tag contains 'expiry:'
      assign expiry_date = tag | split: 'expiry:' | last | strip
    endif
  endfor

  assign first_name = customer.first_name | strip
  if first_name == blank
    assign first_name = 'there'
  endif
  assign order_count = customer.orders_count
-%}

<div class="qy-account">
  <div class="qy-account__inner">

    {%- render 'account-sidebar', active: 'overview' -%}

    <div class="qy-main">
      <section class="qy-section-gap">

        <!-- header -->
        <div>
          <div class="qy-eyebrow">Account · Overview</div>
          <h1 class="qy-h1">Welcome back, <em>{{ first_name }}</em>.</h1>
          <p class="qy-lead">Your prescription, orders and deliveries live here.</p>
        </div>

        {%- if has_active_script -%}
          {%- comment -%}
            Hidden: the "Prescription active" hero is not functional yet
            (auto-delivery / view-script actions don't work). Kept for restore.

          <!-- active-script hero -->
          <div class="qy-hero">
            <div class="qy-hero__top">
              <div class="qy-hero__lead">
                <div class="qy-hero__status"><span class="qy-dot"></span>Prescription active</div>
                <h2 class="qy-hero__title">{{ rx_name }}</h2>
                <p class="qy-hero__body">
                  {%- if rx_prescriber != blank -%}Prescribed by {{ rx_prescriber }}. {% endif -%}
                  {%- if rx_repeats != blank -%}{{ rx_repeats }} repeats remaining. {% endif -%}
                  Manage your therapy, deliveries and check-ins below.
                </p>
              </div>
              {%- if rx_script_id != blank or expiry_date != blank -%}
                <div class="qy-hero__meta">
                  {%- if rx_script_id != blank -%}{{ rx_script_id }}<br>{% endif -%}
                  {%- if expiry_date != blank -%}Expires {{ expiry_date }}{% endif -%}
                </div>
              {%- endif -%}
            </div>
            <div class="qy-hero__actions">
              <a href="/pages/auto-delivery" class="qy-btn qy-btn--paper">Manage auto-delivery</a>
              <a href="/pages/prescription" class="qy-btn qy-btn--ghost-dark">View script</a>
            </div>
          </div>
          {%- endcomment -%}
        {%- else -%}
          <!-- application hero -->
          <div class="qy-hero">
            <div class="qy-hero__top">
              <div class="qy-hero__lead">
                <div class="qy-hero__eyebrow">Get started</div>
                <h2 class="qy-hero__title">Apply for your prescription</h2>
                <p class="qy-hero__body">A quick health questionnaire, reviewed by an Australian-registered doctor within 24 hours. You only pay if you're approved.</p>
              </div>
              <div class="qy-hero__meta">Step 01 / 04<br>~2 minutes</div>
            </div>

            <div class="qy-stepper">
              <div class="qy-step">
                <span class="qy-step__num qy-step__num--active">1</span>
                <span class="qy-step__label qy-step__label--active">Open an account</span>
              </div>
              <span class="qy-stepper__line"></span>
              <div class="qy-step">
                <span class="qy-step__num">2</span>
                <span class="qy-step__label">Complete intake</span>
              </div>
              <span class="qy-stepper__line"></span>
              <div class="qy-step">
                <span class="qy-step__num">3</span>
                <span class="qy-step__label">Doctor review</span>
              </div>
              <span class="qy-stepper__line"></span>
              <div class="qy-step">
                <span class="qy-step__num">4</span>
                <span class="qy-step__label">Get notified</span>
              </div>
            </div>

            <div class="qy-hero__actions">
              <a href="/pages/questionnaire" class="qy-btn qy-btn--coral">Start intake
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg>
              </a>
              <span class="qy-hero__note">Free to apply. No charge until you speak to a doctor.</span>
            </div>
          </div>
        {%- endif -%}

        <!-- recent orders -->
        <div class="qy-1col">
          <div class="qy-card" id="account-orders">
            <div class="qy-card__head">
              <h3 class="qy-card__title">Recent orders</h3>
              {%- if customer.orders.size > 0 -%}
                <a href="/account#account-orders" class="qy-link-muted">View all</a>
              {%- endif -%}
            </div>

            {%- if customer.orders.size > 0 -%}
              <div class="qy-orders">
                {%- for order in customer.orders limit: 4 -%}
                  <a href="{{ order.customer_url }}" class="qy-order-row">
                    <div>
                      <div class="qy-order-row__name">{{ order.name }}</div>
                      <div class="qy-order-row__meta">{{ order.created_at | date: "%d %b %Y" }}</div>
                    </div>
                    <div class="qy-order-row__right">
                      <div class="qy-order-row__total">{{ order.total_price | money }}</div>
                      <div class="qy-order-row__status">{{ order.fulfillment_status_label }}</div>
                    </div>
                  </a>
                {%- endfor -%}
              </div>
            {%- else -%}
              <div class="qy-empty">
                <div class="qy-empty__chip">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7l8-3 8 3-8 3z"></path><path d="M4 7v10l8 3 8-3V7"></path><path d="M12 10v10"></path></svg>
                </div>
                <div class="qy-empty__title">No orders yet</div>
                <div class="qy-empty__copy">Once a doctor approves your application, your scripts and orders appear here.</div>
                <a href="/collections/all" class="qy-btn qy-btn--secondary qy-btn--44">Shop pharmacy</a>
              </div>
            {%- endif -%}
          </div>

          {%- comment -%}
            Hidden: the Resources card links are not wired up yet. Kept for restore.

          <div class="qy-card">
            <h3 class="qy-card__title">Resources</h3>
            <div class="qy-res">
              <a href="/blogs/news" class="qy-res__item"><span>How nicotine therapy works</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg></a>
              <a href="/blogs/news" class="qy-res__item"><span>Read the CMI leaflet</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg></a>
              <a href="/blogs/news" class="qy-res__item"><span>What to expect in weeks 1–6</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg></a>
              <a href="/pages/contact" class="qy-res__item"><span>Talk to the care team</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg></a>
            </div>
          </div>
          {%- endcomment -%}
        </div>

        <!-- addresses summary -->
        <div class="qy-card">
          <div class="qy-card__head" style="margin-bottom:18px;">
            <h3 class="qy-card__title">Your addresses</h3>
            <a href="/account/addresses" class="qy-link-muted">Manage</a>
          </div>
          <div class="qy-addr-grid">
            {%- assign primary = customer.default_address -%}
            {%- if primary -%}
              <div class="qy-addr-card">
                <div class="qy-addr__label">Primary · Delivery</div>
                <div class="qy-addr__name">{{ primary.first_name }} {{ primary.last_name }}</div>
                <div class="qy-addr__lines">
                  {%- assign addr_line1 = '' -%}
                  {%- if primary.address1 != blank -%}{%- assign addr_line1 = primary.address1 -%}{%- endif -%}
                  {%- if primary.address2 != blank -%}{%- if addr_line1 != '' -%}{%- assign addr_line1 = addr_line1 | append: ', ' -%}{%- endif -%}{%- assign addr_line1 = addr_line1 | append: primary.address2 -%}{%- endif -%}
                  {%- if primary.city != blank -%}{%- if addr_line1 != '' -%}{%- assign addr_line1 = addr_line1 | append: ', ' -%}{%- endif -%}{%- assign addr_line1 = addr_line1 | append: primary.city -%}{%- endif -%}
                  {%- assign addr_line2 = '' -%}
                  {%- if primary.province_code != blank -%}{%- assign addr_line2 = primary.province_code -%}{%- endif -%}
                  {%- if primary.zip != blank -%}{%- if addr_line2 != '' -%}{%- assign addr_line2 = addr_line2 | append: ' ' -%}{%- endif -%}{%- assign addr_line2 = addr_line2 | append: primary.zip -%}{%- endif -%}
                  {%- if primary.country != blank -%}{%- if addr_line2 != '' -%}{%- assign addr_line2 = addr_line2 | append: ' · ' -%}{%- endif -%}{%- assign addr_line2 = addr_line2 | append: primary.country -%}{%- endif -%}
                  {%- if addr_line1 != '' -%}{{ addr_line1 }}{%- if addr_line2 != '' -%}<br>{%- endif -%}{%- endif -%}{{ addr_line2 }}
                </div>
              </div>
            {%- else -%}
              <div class="qy-addr-card qy-addr-card--dashed">
                <div class="qy-addr__label">Primary · Delivery</div>
                <div class="qy-addr__lines">No delivery address yet.</div>
                <a href="/account/addresses" class="qy-btn qy-btn--secondary qy-btn--38">Add delivery address</a>
              </div>
            {%- endif -%}

            {%- if customer.addresses.size > 1 -%}
              {%- assign billing = customer.addresses[1] -%}
              <div class="qy-addr-card">
                <div class="qy-addr__label">Billing</div>
                <div class="qy-addr__name">{{ billing.first_name }} {{ billing.last_name }}</div>
                <div class="qy-addr__lines">
                  {%- assign bill_line1 = '' -%}
                  {%- if billing.address1 != blank -%}{%- assign bill_line1 = billing.address1 -%}{%- endif -%}
                  {%- if billing.city != blank -%}{%- if bill_line1 != '' -%}{%- assign bill_line1 = bill_line1 | append: ', ' -%}{%- endif -%}{%- assign bill_line1 = bill_line1 | append: billing.city -%}{%- endif -%}
                  {%- assign bill_line2 = '' -%}
                  {%- if billing.province_code != blank -%}{%- assign bill_line2 = billing.province_code -%}{%- endif -%}
                  {%- if billing.zip != blank -%}{%- if bill_line2 != '' -%}{%- assign bill_line2 = bill_line2 | append: ' ' -%}{%- endif -%}{%- assign bill_line2 = bill_line2 | append: billing.zip -%}{%- endif -%}
                  {%- if billing.country != blank -%}{%- if bill_line2 != '' -%}{%- assign bill_line2 = bill_line2 | append: ' · ' -%}{%- endif -%}{%- assign bill_line2 = bill_line2 | append: billing.country -%}{%- endif -%}
                  {%- if bill_line1 != '' -%}{{ bill_line1 }}{%- if bill_line2 != '' -%}<br>{%- endif -%}{%- endif -%}{{ bill_line2 }}
                </div>
              </div>
            {%- else -%}
              <div class="qy-addr-card qy-addr-card--dashed">
                <div class="qy-addr__label">Billing</div>
                <div class="qy-addr__lines">Not added yet.</div>
                <a href="/account/addresses" class="qy-btn qy-btn--secondary qy-btn--38">Add billing address</a>
              </div>
            {%- endif -%}
          </div>
        </div>

        <!-- trust strip -->
        <div class="qy-trust">
          <div class="qy-trust__pill"><svg viewBox="0 0 24 24" fill="none" stroke="#0F1110" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M8.5 12.5l2.2 2.2 4.8-5"></path></svg>TGA-licensed pharmacy</div>
          <div class="qy-trust__pill"><svg viewBox="0 0 24 24" fill="none" stroke="#0F1110" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"></path></svg>AHPRA-registered doctors</div>
          <div class="qy-trust__pill"><svg viewBox="0 0 24 24" fill="none" stroke="#0F1110" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="1.5"></rect><path d="M8 11V8a4 4 0 0 1 8 0v3"></path></svg>Data stored in Australia</div>
        </div>

      </section>
    </div>
  </div>
</div>
