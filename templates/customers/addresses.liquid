{{ 'account-dashboard.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  The new/edit address forms keep the IDs and classes that
  assets/theme.js → customerAddressForm() wires up:
    #AddressNewForm, .address-new-toggle, #EditAddress_{id},
    .address-edit-toggle, .address-delete, the country/province
    selectors (#AddressCountryNew / .address-country-option …).
{%- endcomment -%}

{%- paginate customer.addresses by 6 -%}
<div class="qy-account">
  <div class="qy-account__inner">

    {%- render 'account-sidebar', active: 'addresses' -%}

    <div class="qy-main">
      <section class="qy-section-gap">

        <!-- header -->
        <div>
          <div class="qy-eyebrow">Account · Addresses</div>
          <h1 class="qy-h1 qy-h1--sm">Addresses</h1>
          <p class="qy-lead qy-lead--sm">Where we deliver and bill. Your delivery address must be a residential address in Australia.</p>
        </div>

        <!-- saved addresses -->
        {%- if customer.addresses.size > 0 -%}
          <div class="qy-addr-grid">
            {%- for address in customer.addresses -%}
              {%- assign is_default = false -%}
              {%- if address == customer.default_address -%}{%- assign is_default = true -%}{%- endif -%}
              <div class="qy-addr-card qy-addr-card--lg">
                <div class="qy-card__head">
                  <div class="qy-addr__label">{% if is_default %}Primary · Delivery{% else %}Address{% endif %}</div>
                  {%- if is_default -%}<span class="qy-pill--default">Default</span>{%- endif -%}
                </div>
                <div class="qy-addr__name">{{ address.first_name }} {{ address.last_name }}</div>
                <div class="qy-addr__lines">
                  {%- if address.company != blank -%}{{ address.company }}<br>{%- endif -%}
                  {{ address.address1 }}{% if address.address2 != blank %}, {{ address.address2 }}{% endif %}<br>
                  {{ address.city }} {{ address.province_code }} {{ address.zip }}<br>
                  {{ address.country }}
                </div>
                <div class="qy-addr-actions">
                  <button type="button" class="qy-btn qy-btn--secondary qy-btn--40 address-edit-toggle" data-form-id="{{ address.id }}">{{ 'customer.addresses.edit' | t }}</button>
                  <button type="button" class="qy-btn qy-btn--text address-delete" data-form-id="{{ address.id }}" data-confirm-message="{{ 'customer.addresses.delete_confirm' | t }}">{{ 'customer.addresses.delete' | t }}</button>
                </div>

                <!-- edit form -->
                <div id="EditAddress_{{ address.id }}" class="qy-addr-edit hide">
                  {%- form 'customer_address', address -%}
                    <div class="qy-form__grid">
                      <div class="qy-field">
                        <label class="qy-label" for="AddressFirstName_{{ form.id }}">{{ 'customer.addresses.first_name' | t }}</label>
                        <input class="qy-input" type="text" id="AddressFirstName_{{ form.id }}" name="address[first_name]" value="{{ form.first_name }}">
                      </div>
                      <div class="qy-field">
                        <label class="qy-label" for="AddressLastName_{{ form.id }}">{{ 'customer.addresses.last_name' | t }}</label>
                        <input class="qy-input" type="text" id="AddressLastName_{{ form.id }}" name="address[last_name]" value="{{ form.last_name }}">
                      </div>
                      <div class="qy-field qy-field--full">
                        <label class="qy-label" for="AddressAddress1_{{ form.id }}">{{ 'customer.addresses.address1' | t }}</label>
                        <input class="qy-input" type="text" id="AddressAddress1_{{ form.id }}" name="address[address1]" value="{{ form.address1 }}">
                      </div>
                      <div class="qy-field qy-field--full">
                        <label class="qy-label" for="AddressAddress2_{{ form.id }}">{{ 'customer.addresses.address2' | t }}</label>
                        <input class="qy-input" type="text" id="AddressAddress2_{{ form.id }}" name="address[address2]" value="{{ form.address2 }}">
                      </div>
                      <div class="qy-field qy-field--full">
                        <label class="qy-label" for="AddressCountry_{{ form.id }}">{{ 'customer.addresses.country' | t }}</label>
                        <select class="qy-input address-country-option" id="AddressCountry_{{ form.id }}" data-form-id="{{ form.id }}" name="address[country]" data-default="{{ form.country }}">{{ all_country_option_tags }}</select>
                      </div>
                      <div class="qy-field qy-field--full" id="AddressProvinceContainer_{{ form.id }}" style="display:none">
                        <label class="qy-label" for="AddressProvince_{{ form.id }}">{{ 'customer.addresses.province' | t }}</label>
                        <select class="qy-input" id="AddressProvince_{{ form.id }}" name="address[province]" data-default="{{ form.province }}"></select>
                      </div>
                      <div class="qy-field">
                        <label class="qy-label" for="AddressCity_{{ form.id }}">{{ 'customer.addresses.city' | t }}</label>
                        <input class="qy-input" type="text" id="AddressCity_{{ form.id }}" name="address[city]" value="{{ form.city }}">
                      </div>
                      <div class="qy-field">
                        <label class="qy-label" for="AddressZip_{{ form.id }}">{{ 'customer.addresses.zip' | t }}</label>
                        <input class="qy-input" type="text" id="AddressZip_{{ form.id }}" name="address[zip]" value="{{ form.zip }}" autocapitalize="characters">
                      </div>
                      <div class="qy-field qy-field--full">
                        <label class="qy-label" for="AddressPhone_{{ form.id }}">{{ 'customer.addresses.phone' | t }}</label>
                        <input class="qy-input" type="tel" id="AddressPhone_{{ form.id }}" name="address[phone]" value="{{ form.phone }}">
                      </div>
                    </div>
                    <label class="qy-check">
                      {{ form.set_as_default_checkbox }}
                      {{ 'customer.addresses.set_default' | t }}
                    </label>
                    <div class="qy-form__actions">
                      <button type="submit" class="qy-btn qy-btn--ink">{{ 'customer.addresses.update' | t }}</button>
                      <button type="button" class="qy-btn--text address-edit-toggle" data-form-id="{{ form.id }}">{{ 'customer.addresses.cancel' | t }}</button>
                    </div>
                  {%- endform -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <!-- add a new address -->
        <div>
          <button type="button" class="qy-btn qy-btn--ink address-new-toggle">{{ 'customer.addresses.add_new' | t }}</button>
        </div>

        <div id="AddressNewForm" class="qy-card hide">
          <h3 class="qy-form__title">{{ 'customer.addresses.add_new' | t }}</h3>
          {%- form 'customer_address', customer.new_address -%}
            {{ form.errors | default_errors }}
            <div class="qy-form__grid">
              <div class="qy-field">
                <label class="qy-label" for="AddressFirstNameNew">{{ 'customer.addresses.first_name' | t }}</label>
                <input class="qy-input" type="text" id="AddressFirstNameNew" name="address[first_name]" value="{{ form.first_name }}" placeholder="First name">
              </div>
              <div class="qy-field">
                <label class="qy-label" for="AddressLastNameNew">{{ 'customer.addresses.last_name' | t }}</label>
                <input class="qy-input" type="text" id="AddressLastNameNew" name="address[last_name]" value="{{ form.last_name }}" placeholder="Last name">
              </div>
              <div class="qy-field qy-field--full">
                <label class="qy-label" for="AddressAddress1New">{{ 'customer.addresses.address1' | t }}</label>
                <input class="qy-input" type="text" id="AddressAddress1New" name="address[address1]" value="{{ form.address1 }}" placeholder="Unit / street number and name">
              </div>
              <div class="qy-field qy-field--full">
                <label class="qy-label" for="AddressAddress2New">{{ 'customer.addresses.address2' | t }}</label>
                <input class="qy-input" type="text" id="AddressAddress2New" name="address[address2]" value="{{ form.address2 }}" placeholder="Apartment, suite, etc. (optional)">
              </div>
              <div class="qy-field qy-field--full">
                <label class="qy-label" for="AddressCountryNew">{{ 'customer.addresses.country' | t }}</label>
                <select class="qy-input" id="AddressCountryNew" name="address[country]" data-default="{{ form.country }}">{{ all_country_option_tags }}</select>
              </div>
              <div class="qy-field qy-field--full" id="AddressProvinceContainerNew" style="display:none">
                <label class="qy-label" for="AddressProvinceNew">{{ 'customer.addresses.province' | t }}</label>
                <select class="qy-input" id="AddressProvinceNew" name="address[province]" data-default="{{ form.province }}"></select>
              </div>
              <div class="qy-field">
                <label class="qy-label" for="AddressCityNew">{{ 'customer.addresses.city' | t }}</label>
                <input class="qy-input" type="text" id="AddressCityNew" name="address[city]" value="{{ form.city }}" placeholder="Suburb">
              </div>
              <div class="qy-field">
                <label class="qy-label" for="AddressZipNew">{{ 'customer.addresses.zip' | t }}</label>
                <input class="qy-input" type="text" id="AddressZipNew" name="address[zip]" value="{{ form.zip }}" autocapitalize="characters" placeholder="Postcode">
              </div>
              <div class="qy-field qy-field--full">
                <label class="qy-label" for="AddressPhoneNew">{{ 'customer.addresses.phone' | t }}</label>
                <input class="qy-input" type="tel" id="AddressPhoneNew" name="address[phone]" value="{{ form.phone }}" placeholder="Phone (optional)">
              </div>
            </div>
            <label class="qy-check">
              {{ form.set_as_default_checkbox }}
              {{ 'customer.addresses.set_default' | t }}
            </label>
            <div class="qy-form__actions">
              <button type="submit" class="qy-btn qy-btn--ink">{{ 'customer.addresses.add' | t }}</button>
              <button type="button" class="qy-btn--text address-new-toggle">{{ 'customer.addresses.cancel' | t }}</button>
            </div>
          {%- endform -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="pagination">
            {{ paginate | default_pagination | replace: '&laquo; Previous', '&larr;' | replace: 'Next &raquo;', '&rarr;' }}
          </div>
        {%- endif -%}

      </section>
    </div>
  </div>
</div>
{%- endpaginate -%}
