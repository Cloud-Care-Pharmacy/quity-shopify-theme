          "type": "service",
          "settings": {
            "icon": "",
            "image": "",
            "title": "Immediate",
            "des": "<p><strong>Within 20 minutes:</strong> Heart rate and blood pressure drop to normal levels.</p><p><strong>Within 12 hours:</strong> Carbon monoxide levels in your blood return to normal.</p><p><strong>Within 24 hours:</strong> Your risk of heart attack begins to decrease.</p>"
          }
        },
        "benefit-short-term": {
          "type": "service",
          "settings": {
            "icon": "",
            "image": "",
            "title": "Short Term",
            "des": "<p><strong>2 weeks - 3 months:</strong> Circulation improves and lung function increases.</p><p><strong>1-9 months:</strong> Coughing and shortness of breath decrease. Your lungs start to repair themselves.</p><p><strong>Energy levels:</strong> You'll notice increased energy and improved sense of taste and smell.</p>"
          }
        },
        "benefit-long-term": {
          "type": "service",
          "settings": {
            "icon": "",
            "image": "",
            "title": "Long Term",
            "des": "<p><strong>1 year:</strong> Risk of heart disease is cut in half compared to a smoker.</p><p><strong>5-10 years:</strong> Stroke risk reduced to that of a non-smoker.</p><p><strong>10-15 years:</strong> Cancer risk drops significantly, and overall health greatly improves.</p>"
          }
        }
