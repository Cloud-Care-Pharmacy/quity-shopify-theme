    "calculator-section": {
      "type": "advanced-content",
      "blocks": {
        "calculator-image": {
          "type": "html",
          "settings": {
            "code": "<div class=\"calculator-image-wrapper\" style=\"background: linear-gradient(135deg, rgba(26,26,26,0.8), rgba(173,44,52,0.7)), url('https://images.unsplash.com/photo-1579621970563-ebec7560ff3e?w=800') center/cover; min-height: 500px; display: flex; align-items: center; justify-content: center; color: white; border-radius: 8px;\"><div style=\"text-align: center; padding: 40px;\"></div></div>",
            "width": "50%"
          }
        },
        "calculator-form": {
          "type": "html",
          "settings": {
            "code": "<div class=\"savings-calculator\" style=\"background: #1a1a1a; color: white; padding: 60px 40px; border-radius: 8px;\">\n  <h2 style=\"color: white; margin-bottom: 10px; font-size: 36px;\">Improve Your Wealth</h2>\n  <p style=\"color: #ccc; margin-bottom: 30px; font-size: 18px;\">Quitting smoking will save you thousands</p>\n  \n  <div style=\"margin-bottom: 25px;\">\n    <label style=\"display: block; margin-bottom: 8px; color: #ccc;\">Cigarettes per day</label>\n    <input type=\"number\" id=\"cigs-per-day\" value=\"20\" min=\"1\" max=\"60\" style=\"width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #444; background: #2a2a2a; color: white; font-size: 16px;\">\n  </div>\n  \n  <div style=\"margin-bottom: 25px;\">\n    <label style=\"display: block; margin-bottom: 8px; color: #ccc;\">Price per pack (20 cigarettes)</label>\n    <input type=\"number\" id=\"price-per-pack\" value=\"40\" min=\"1\" max=\"100\" step=\"0.50\" style=\"width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #444; background: #2a2a2a; color: white; font-size: 16px;\">\n  </div>\n  \n  <button onclick=\"calculateSavings()\" style=\"width: 100%; padding: 15px; background: #ad2c34; color: white; border: none; border-radius: 4px; font-size: 18px; font-weight: bold; cursor: pointer; margin-bottom: 30px;\">Calculate Savings</button>\n  \n  <div id=\"results\" style=\"display: none;\">\n    <h3 style=\"color: #ad2c34; margin-bottom: 20px; font-size: 24px;\">Your Potential Savings:</h3>\n    <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 20px;\">\n      <div style=\"background: #2a2a2a; padding: 20px; border-radius: 8px; text-align: center;\">\n        <div style=\"font-size: 32px; font-weight: bold; color: #4ade80; margin-bottom: 5px;\" id=\"daily-savings\">$0</div>\n        <div style=\"color: #999; font-size: 14px;\">Daily</div>\n      </div>\n      <div style=\"background: #2a2a2a; padding: 20px; border-radius: 8px; text-align: center;\">\n        <div style=\"font-size: 32px; font-weight: bold; color: #4ade80; margin-bottom: 5px;\" id=\"weekly-savings\">$0</div>\n        <div style=\"color: #999; font-size: 14px;\">Weekly</div>\n      </div>\n      <div style=\"background: #2a2a2a; padding: 20px; border-radius: 8px; text-align: center;\">\n        <div style=\"font-size: 32px; font-weight: bold; color: #4ade80; margin-bottom: 5px;\" id=\"monthly-savings\">$0</div>\n        <div style=\"color: #999; font-size: 14px;\">Monthly</div>\n      </div>\n      <div style=\"background: #2a2a2a; padding: 20px; border-radius: 8px; text-align: center;\">\n        <div style=\"font-size: 32px; font-weight: bold; color: #4ade80; margin-bottom: 5px;\" id=\"yearly-savings\">$0</div>\n        <div style=\"color: #999; font-size: 14px;\">Yearly</div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\nfunction calculateSavings() {\n  const cigsPerDay = parseFloat(document.getElementById('cigs-per-day').value) || 0;\n  const pricePerPack = parseFloat(document.getElementById('price-per-pack').value) || 0;\n  \n  const dailyCost = (cigsPerDay / 20) * pricePerPack;\n  const weeklySavings = dailyCost * 7;\n  const monthlySavings = dailyCost * 30;\n  const yearlySavings = dailyCost * 365;\n  \n  document.getElementById('daily-savings').textContent = '$' + dailyCost.toFixed(2);\n  document.getElementById('weekly-savings').textContent = '$' + weeklySavings.toFixed(2);\n  document.getElementById('monthly-savings').textContent = '$' + monthlySavings.toFixed(2);\n  document.getElementById('yearly-savings').textContent = '$' + yearlySavings.toFixed(0);\n  \n  document.getElementById('results').style.display = 'block';\n}\n</script>",
            "width": "50%"
          }
        }
